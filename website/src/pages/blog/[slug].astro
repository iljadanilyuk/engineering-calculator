---
import { renderBlogContentHtml } from '@poznyak-engineering-calculator/contracts'

import PublicFontLinks from '../../components/PublicFontLinks.astro'
import SiteHeader from '../../components/SiteHeader.astro'
import {
  blogCoverImageUrl,
  formatBlogDate,
  loadBlogPostDetails,
  type BlogPost,
} from '../../lib/blog-posts'
import { absoluteUrl, createPageMeta, serializeJsonLd, siteName } from '../../lib/seo'

export async function getStaticPaths() {
  const posts = await loadBlogPostDetails()
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }))
}

type Props = {
  post: BlogPost
}

const { post } = Astro.props
const coverImage = blogCoverImageUrl(post)
const pageMeta = createPageMeta({
  siteUrl: import.meta.env.PUBLIC_WEBSITE_URL,
  path: `/blog/${post.slug}/`,
  title: post.seoTitleResolved,
  description: post.seoDescriptionResolved,
  imagePath: coverImage,
})
const contentHtml = renderBlogContentHtml(post.content)
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  '@id': `${pageMeta.canonicalUrl}#article`,
  mainEntityOfPage: pageMeta.canonicalUrl,
  headline: post.title,
  description: post.excerpt,
  image: absoluteUrl(pageMeta.siteUrl, coverImage),
  datePublished: post.publishedAt,
  dateModified: post.updatedAt,
  author: {
    '@type': 'Organization',
    name: siteName,
  },
  publisher: {
    '@type': 'Organization',
    name: siteName,
  },
  articleSection: post.category ?? 'Инженерное проектирование',
  keywords: post.tags,
}
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <PublicFontLinks />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageMeta.title}</title>
    <meta name="description" content={pageMeta.description} />
    <meta name="robots" content={pageMeta.robots} />
    <link rel="canonical" href={pageMeta.canonicalUrl} />
    <meta property="og:locale" content="ru_BY" />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageMeta.title} />
    <meta property="og:description" content={pageMeta.description} />
    <meta property="og:url" content={pageMeta.canonicalUrl} />
    <meta property="og:image" content={pageMeta.imageUrl} />
    <meta property="og:image:secure_url" content={pageMeta.imageUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:alt" content={post.coverImageAlt} />
    {post.publishedAt && <meta property="article:published_time" content={post.publishedAt} />}
    <meta property="article:modified_time" content={post.updatedAt} />
    {post.category && <meta property="article:section" content={post.category} />}
    {post.tags.map((tag) => <meta property="article:tag" content={tag} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageMeta.title} />
    <meta name="twitter:description" content={pageMeta.description} />
    <meta name="twitter:image" content={pageMeta.imageUrl} />
    <meta name="twitter:image:alt" content={post.coverImageAlt} />
    <script type="application/ld+json" is:inline set:html={serializeJsonLd(structuredData)} />
  </head>
  <body>
    <SiteHeader />

    <main>
      <article>
        <section class="article-hero">
          <div class="shell hero-grid">
            <div class="hero-copy">
              <a class="back-link" href="/blog/">Блог</a>
              <p class="eyebrow">
                {formatBlogDate(post.publishedAt)}{post.category ? ` · ${post.category}` : ''}
              </p>
              <h1>{post.title}</h1>
              <p>{post.excerpt}</p>
              <div class="pill-row" aria-label="Темы статьи">
                {post.tags.map((tag) => <span>{tag}</span>)}
              </div>
            </div>
            <figure class="hero-media">
              <img src={coverImage} alt={post.coverImageAlt} />
            </figure>
          </div>
        </section>

        <section class="section" aria-labelledby="article-content-title">
          <div class="shell article-layout">
            <aside class="article-aside" aria-label="Информация о статье">
              <div>
                <span>Раздел</span>
                <strong>{post.category ?? 'Инженерия'}</strong>
              </div>
              <div>
                <span>Дата</span>
                <strong>{formatBlogDate(post.publishedAt)}</strong>
              </div>
              <a class="secondary-btn" href="/#calculator">Рассчитать проект</a>
            </aside>
            <div class="article-body">
              <h2 id="article-content-title" class="sr-only">{post.title}</h2>
              <div class="article-rich-body" set:html={contentHtml} />
            </div>
          </div>
        </section>
      </article>
    </main>
  </body>
</html>

<style>
  :root {
    --font-heading: "Nunito", "Inter", system-ui, sans-serif;
    --font-body: "Inter", system-ui, sans-serif;
    --ink: #102033;
    --body: #536273;
    --muted: #7f8f9f;
    --line: #dce4ec;
    --paper: #ffffff;
    --soft: #f4f7fa;
    --blue: #0b5fb5;
    --green: #17875d;
    --shadow: 0 18px 50px rgba(16, 32, 51, 0.08);
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    font-family: var(--font-body);
  }

  a {
    color: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    border-bottom: 1px solid rgba(220, 228, 236, 0.88);
    background: rgba(255, 255, 255, 0.95);
    padding: 14px clamp(16px, 4vw, 44px);
    backdrop-filter: blur(14px);
  }

  .brand,
  .header nav,
  .pill-row {
    display: flex;
    align-items: center;
  }

  .brand {
    --brand-mark-size: 34px;
    gap: 10px;
    text-decoration: none;
  }

  .brand-mark {
    width: 34px;
    height: 34px;
    flex: 0 0 34px;
    overflow: visible;
  }

  .brand-mark-bg {
    fill: var(--ink);
  }

  .brand-mark-p,
  .brand-mark-flow {
    fill: none;
    stroke: #ffffff;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .brand-mark-p {
    stroke-width: 3.2;
  }

  .brand-mark-flow {
    stroke: #85c2ff;
    stroke-width: 2.4;
  }

  .brand-mark-node {
    fill: #ffffff;
    stroke: #85c2ff;
    stroke-width: 1.6;
  }

  .brand-copy {
    display: grid;
    min-width: 0;
    gap: 2px;
  }

  .brand-copy strong {
    font-size: 16px;
    font-weight: 800;
    line-height: 1.1;
  }

  .brand-copy > span {
    color: var(--muted);
    font-size: 10px;
    font-weight: 700;
    line-height: 1.1;
  }

  .brand strong,
  h1,
  h2,
  h3 {
    font-family: var(--font-heading);
  }

  .header nav {
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 16px;
    color: var(--body);
    font-size: 14px;
    font-weight: 700;
  }

  .header nav a {
    text-decoration: none;
  }

  .header nav a:hover {
    color: var(--blue);
  }

  .shell {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
  }

  .article-hero {
    border-bottom: 1px solid var(--line);
    background: linear-gradient(180deg, #f7fafc 0%, #ffffff 100%);
    padding: clamp(34px, 7vw, 72px) 0 42px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
    gap: clamp(24px, 5vw, 58px);
    align-items: end;
  }

  .hero-copy {
    max-width: 760px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 18px;
    color: var(--blue);
    font-size: 14px;
    font-weight: 800;
    text-decoration: none;
  }

  .back-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .eyebrow {
    margin: 0 0 10px;
    color: var(--blue);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
  }

  h1 {
    max-width: 780px;
    font-size: clamp(36px, 6vw, 64px);
    line-height: 0.98;
  }

  .hero-copy > p:not(.eyebrow) {
    max-width: 680px;
    margin-top: 18px;
    color: var(--body);
    font-size: 18px;
    line-height: 1.7;
  }

  .pill-row {
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }

  .pill-row span {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 5px 8px;
    color: var(--muted);
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
  }

  .hero-media {
    overflow: hidden;
    margin: 0;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--soft);
    box-shadow: var(--shadow);
  }

  .hero-media img {
    width: 100%;
    min-height: 320px;
    object-fit: cover;
  }

  .section {
    padding: clamp(42px, 7vw, 76px) 0;
  }

  .article-layout {
    display: grid;
    grid-template-columns: 260px minmax(0, 720px);
    gap: clamp(24px, 5vw, 64px);
    align-items: start;
  }

  .article-aside {
    position: sticky;
    top: 86px;
    display: grid;
    gap: 14px;
    border-left: 4px solid var(--green);
    background: var(--soft);
    padding: 20px;
  }

  .article-aside div {
    display: grid;
    gap: 4px;
  }

  .article-aside span {
    color: var(--muted);
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
  }

  .article-aside strong {
    line-height: 1.35;
  }

  .article-body {
    display: grid;
    gap: 18px;
  }

  .article-rich-body {
    display: grid;
    gap: 18px;
  }

  .article-body h2,
  .article-rich-body h2 {
    margin-top: 18px;
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.08;
  }

  .article-body h3,
  .article-rich-body h3 {
    margin-top: 8px;
    font-size: 24px;
    line-height: 1.2;
  }

  .article-body p,
  .article-body li,
  .article-rich-body p,
  .article-rich-body li {
    color: var(--body);
    font-size: 18px;
    line-height: 1.8;
  }

  .article-rich-body a {
    color: var(--blue);
    font-weight: 700;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }

  .article-rich-body blockquote {
    margin: 8px 0;
    border-left: 4px solid var(--green);
    background: var(--soft);
    padding: 16px 20px;
  }

  .article-body ul,
  .article-rich-body ul,
  .article-rich-body ol {
    display: grid;
    gap: 10px;
    margin: 0;
    padding-left: 22px;
  }

  .article-rich-body img {
    width: 100%;
    height: auto;
    border: 1px solid var(--line);
    border-radius: 8px;
    box-shadow: var(--shadow);
  }

  .article-rich-body table {
    width: 100%;
    border-collapse: collapse;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .article-rich-body th,
  .article-rich-body td {
    border: 1px solid var(--line);
    padding: 11px 12px;
    color: var(--body);
    font-size: 16px;
    line-height: 1.55;
    text-align: left;
    vertical-align: top;
  }

  .article-rich-body th {
    background: var(--soft);
    color: var(--ink);
    font-weight: 800;
  }

  .secondary-btn {
    width: fit-content;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
    padding: 10px 14px;
    color: var(--ink);
    font-size: 14px;
    font-weight: 800;
    text-decoration: none;
  }

  .secondary-btn:hover {
    border-color: var(--blue);
    color: var(--blue);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  @media (max-width: 860px) {
    .header,
    .hero-grid,
    .article-layout {
      grid-template-columns: minmax(0, 1fr);
    }

    .header {
      display: grid;
    }

    .header nav {
      justify-content: flex-start;
    }

    .article-aside {
      position: static;
    }

    .hero-media img {
      min-height: 220px;
      max-height: 320px;
    }
  }
</style>
