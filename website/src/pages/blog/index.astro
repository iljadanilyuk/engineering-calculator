---
import ProjectExampleRequestForm from '../../components/ProjectExampleRequestForm.astro'
import PublicFontLinks from '../../components/PublicFontLinks.astro'
import SiteFooter from '../../components/SiteFooter.astro'
import SiteHeader from '../../components/SiteHeader.astro'
import {
  blogCoverImageUrl,
  formatBlogDate,
  loadBlogPosts,
} from '../../lib/blog-posts'
import { createPageMeta, serializeJsonLd, siteName } from '../../lib/seo'

const posts = await loadBlogPosts()
const blogFilterTags = uniqueSortedTags(
  posts.flatMap((post) => postFilterTokens(post)),
)
const pageMeta = createPageMeta({
  siteUrl: import.meta.env.PUBLIC_WEBSITE_URL,
  path: '/blog/',
  title: 'Блог об инженерных проектах | ИП Позняк',
  description:
    'Новости, экспертные материалы и практические статьи по проектированию отопления, вентиляции, водоснабжения и инженерных систем частных домов.',
})
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${pageMeta.canonicalUrl}#webpage`,
  url: pageMeta.canonicalUrl,
  name: pageMeta.title,
  description: pageMeta.description,
  isPartOf: {
    '@type': 'WebSite',
    name: siteName,
    url: pageMeta.siteUrl,
  },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: posts.map((post, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: `${pageMeta.siteUrl}/blog/${post.slug}/`,
      name: post.title,
    })),
  },
}

function postFilterTokens(post: (typeof posts)[number]) {
  return [post.category, ...post.tags].filter((tag): tag is string => Boolean(tag?.trim()))
}

function uniqueSortedTags(values: readonly string[]) {
  return [...new Set(values)].sort((a, b) => a.localeCompare(b, 'ru'))
}
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <PublicFontLinks />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageMeta.title}</title>
    <meta name="description" content={pageMeta.description} />
    <meta name="robots" content={pageMeta.robots} />
    <link rel="canonical" href={pageMeta.canonicalUrl} />
    <meta property="og:locale" content="ru_BY" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageMeta.title} />
    <meta property="og:description" content={pageMeta.description} />
    <meta property="og:url" content={pageMeta.canonicalUrl} />
    <meta property="og:image" content={pageMeta.imageUrl} />
    <meta property="og:image:secure_url" content={pageMeta.imageUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={pageMeta.imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageMeta.title} />
    <meta name="twitter:description" content={pageMeta.description} />
    <meta name="twitter:image" content={pageMeta.imageUrl} />
    <meta name="twitter:image:alt" content={pageMeta.imageAlt} />
    <script type="application/ld+json" is:inline set:html={serializeJsonLd(structuredData)} />
  </head>
  <body>
    <SiteHeader />

    <main>
      <section class="blog-hero">
        <div class="shell hero-grid">
          <div class="hero-copy">
            <p class="eyebrow">Блог и новости</p>
            <h1>Практика инженерного проектирования простым языком</h1>
            <p>
              Короткие материалы о подготовке исходных данных, чтении проектной документации,
              сметах и решениях, которые лучше согласовать до монтажа.
            </p>
          </div>
          <div class="hero-proof" aria-label="Раздел блога">
            <span>экспертные статьи</span>
            <strong>{posts.length}</strong>
            <span>опубликованных материалов</span>
          </div>
        </div>
      </section>

      <section class="section filterable-section" aria-labelledby="blog-list-title" data-filter-region>
        <div class="shell">
          <div class="section-head">
            <p class="eyebrow">Материалы</p>
            <h2 id="blog-list-title">Статьи и обновления</h2>
            <p>Выберите тему, чтобы оставить только материалы по нужному разделу инженерии.</p>
          </div>

          {
            posts.length === 0 ? (
              <div class="empty-state">
                <h3>Публикаций пока нет</h3>
                <p>Когда в админке появятся опубликованные статьи, они будут доступны в этом разделе после следующей сборки сайта.</p>
              </div>
            ) : (
              <>
                <div class="filter-panel" aria-label="Фильтр статей по темам">
                  <div class="filter-chips" data-filter-buttons>
                    <button class="filter-chip is-active" type="button" data-filter-value="" aria-pressed="true">
                      Все
                    </button>
                    {blogFilterTags.map((tag) => (
                      <button class="filter-chip" type="button" data-filter-value={tag} aria-pressed="false">
                        {tag}
                      </button>
                    ))}
                  </div>
                  <span class="filter-count" data-filter-count>{posts.length} материалов</span>
                </div>

                <div class="post-list">
                  {posts.map((post) => (
                    <article class="post-card" data-filter-card data-filter-tags={postFilterTokens(post).join('|')}>
                      <a class="post-cover-link" href={`/blog/${post.slug}/`} aria-label={`Открыть статью: ${post.title}`}>
                        <img src={blogCoverImageUrl(post)} alt={post.coverImageAlt} loading="lazy" />
                      </a>
                      <div class="post-card-body">
                        <div class="post-meta">
                          <span>{formatBlogDate(post.publishedAt)}</span>
                          {post.category && <span>{post.category}</span>}
                        </div>
                        <h3>
                          <a href={`/blog/${post.slug}/`}>{post.title}</a>
                        </h3>
                        <p>{post.excerpt}</p>
                        <div class="pill-row" aria-label="Темы статьи">
                          {post.tags.map((tag) => <span>{tag}</span>)}
                        </div>
                        <a class="secondary-btn" href={`/blog/${post.slug}/`}>Читать статью</a>
                      </div>
                    </article>
                  ))}
                </div>

                <div class="empty-state filter-empty" data-filter-empty hidden>
                  <h3>По этой теме пока нет материалов</h3>
                  <p>Выберите другой тег или вернитесь ко всем публикациям.</p>
                </div>
              </>
            )
          }
        </div>
      </section>

      <section class="section soft request-section" aria-labelledby="blog-example-title">
        <div class="shell narrow">
          <div class="section-head">
            <p class="eyebrow">Получить пример</p>
            <h2 id="blog-example-title">Получить пример инженерного проекта</h2>
            <p>Оставьте контакт, и мы согласуем удобный способ показать доступный пример проектной документации.</p>
          </div>
          <ProjectExampleRequestForm
            id="blog-example-request-form"
            title="Получить пример проекта"
            description="Оставьте имя и контакт: менеджер пришлет доступный пример проекта."
            source="blog_listing"
            submitLabel="Получить пример"
          />
        </div>
      </section>
    </main>
    <SiteFooter />
  </body>
</html>

<script>
  document.querySelectorAll<HTMLElement>('[data-filter-region]').forEach((region) => {
    const buttons = [...region.querySelectorAll<HTMLButtonElement>('[data-filter-value]')]
    const cards = [...region.querySelectorAll<HTMLElement>('[data-filter-card]')]
    const empty = region.querySelector<HTMLElement>('[data-filter-empty]')
    const count = region.querySelector<HTMLElement>('[data-filter-count]')

    const applyFilter = (rawValue: string) => {
      const activeValue = normalizeFilterValue(rawValue)
      let visibleCount = 0

      cards.forEach((card) => {
        const tokens = (card.dataset.filterTags ?? '')
          .split('|')
          .map(normalizeFilterValue)
          .filter(Boolean)
        const visible = !activeValue || tokens.includes(activeValue)
        card.hidden = !visible
        if (visible) visibleCount += 1
      })

      buttons.forEach((button) => {
        const isActive = normalizeFilterValue(button.dataset.filterValue ?? '') === activeValue
        button.classList.toggle('is-active', isActive)
        button.setAttribute('aria-pressed', String(isActive))
      })

      if (empty) empty.hidden = visibleCount > 0
      if (count) {
        count.textContent = activeValue
          ? `Показано ${visibleCount} из ${cards.length}`
          : `${cards.length} материалов`
      }
    }

    buttons.forEach((button) => {
      button.addEventListener('click', () => applyFilter(button.dataset.filterValue ?? ''))
    })
  })

  function normalizeFilterValue(value: string) {
    return value.trim().toLocaleLowerCase('ru-RU')
  }
</script>

<style>
  :root {
    --font-heading: "Nunito", "Inter", system-ui, sans-serif;
    --font-body: "Inter", system-ui, sans-serif;
    --ink: #102033;
    --body: #536273;
    --muted: #7f8f9f;
    --line: #dce4ec;
    --paper: #ffffff;
    --soft: #f4f7fa;
    --blue: #0b5fb5;
    --green: #17875d;
    --shadow: 0 18px 50px rgba(16, 32, 51, 0.08);
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    font-family: var(--font-body);
  }

  a {
    color: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    border-bottom: 1px solid rgba(220, 228, 236, 0.88);
    background: rgba(255, 255, 255, 0.95);
    padding: 14px clamp(16px, 4vw, 44px);
    backdrop-filter: blur(14px);
  }

  .brand,
  .header nav,
  .post-meta,
  .pill-row {
    display: flex;
    align-items: center;
  }

  .brand {
    --brand-mark-size: 34px;
    gap: 10px;
    text-decoration: none;
  }

  .brand-mark {
    width: 34px;
    height: 34px;
    flex: 0 0 34px;
    overflow: visible;
  }

  .brand-mark-bg {
    fill: var(--ink);
  }

  .brand-mark-p,
  .brand-mark-flow {
    fill: none;
    stroke: #ffffff;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .brand-mark-p {
    stroke-width: 3.2;
  }

  .brand-mark-flow {
    stroke: #85c2ff;
    stroke-width: 2.4;
  }

  .brand-mark-node {
    fill: #ffffff;
    stroke: #85c2ff;
    stroke-width: 1.6;
  }

  .brand-copy {
    display: grid;
    min-width: 0;
    gap: 2px;
  }

  .brand-copy strong {
    font-size: 16px;
    font-weight: 800;
    line-height: 1.1;
  }

  .brand-copy > span {
    color: var(--muted);
    font-size: 10px;
    font-weight: 700;
    line-height: 1.1;
  }

  .brand strong,
  h1,
  h2,
  h3 {
    font-family: var(--font-heading);
  }

  .header nav {
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 16px;
    color: var(--body);
    font-size: 14px;
    font-weight: 700;
  }

  .header nav a {
    text-decoration: none;
  }

  .header nav a[aria-current="page"],
  .header nav a:hover {
    color: var(--blue);
  }

  .shell {
    width: min(1120px, calc(100% - 32px));
    margin: 0 auto;
  }

  .shell.narrow {
    width: min(780px, calc(100% - 32px));
  }

  .blog-hero {
    border-bottom: 1px solid var(--line);
    background: linear-gradient(180deg, #f7fafc 0%, #ffffff 100%);
    padding: clamp(42px, 7vw, 82px) 0 46px;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 270px;
    gap: clamp(24px, 5vw, 64px);
    align-items: end;
  }

  .hero-copy {
    max-width: 760px;
  }

  .eyebrow {
    margin: 0 0 10px;
    color: var(--blue);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin: 0;
  }

  h1 {
    max-width: 760px;
    font-size: clamp(36px, 7vw, 68px);
    line-height: 0.96;
  }

  .hero-copy > p:last-child,
  .section-head p,
  .post-card p,
  .empty-state p {
    color: var(--body);
    line-height: 1.7;
  }

  .hero-copy > p:last-child {
    max-width: 680px;
    margin-top: 18px;
    font-size: 18px;
  }

  .hero-proof {
    display: grid;
    gap: 5px;
    border-left: 4px solid var(--green);
    background: var(--paper);
    box-shadow: var(--shadow);
    padding: 22px;
  }

  .hero-proof span,
  .post-meta,
  .pill-row span {
    color: var(--muted);
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
  }

  .hero-proof strong {
    font-size: 46px;
    line-height: 1;
  }

  .section {
    padding: clamp(42px, 7vw, 72px) 0;
  }

  .section.soft {
    background: var(--soft);
  }

  .section-head {
    display: grid;
    max-width: 760px;
    gap: 8px;
    margin-bottom: 24px;
  }

  h2 {
    font-size: clamp(28px, 4vw, 42px);
    line-height: 1.05;
  }

  .filter-panel {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
    border: 1px solid rgba(183, 206, 227, 0.9);
    border-radius: 8px;
    background: #f8fbfe;
    padding: 12px;
  }

  .filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .filter-chip {
    min-height: 38px;
    border: 1px solid #cfe0ee;
    border-radius: 8px;
    background: #ffffff;
    color: var(--body);
    padding: 0 12px;
    font: inherit;
    font-size: 13px;
    font-weight: 800;
    cursor: pointer;
    transition: border-color 0.18s ease, background 0.18s ease, color 0.18s ease, transform 0.18s ease;
  }

  .filter-chip:hover {
    border-color: rgba(11, 95, 181, 0.42);
    color: var(--blue);
    transform: translateY(-1px);
  }

  .filter-chip.is-active {
    border-color: var(--blue);
    background: var(--blue);
    color: #ffffff;
  }

  .filter-count {
    flex: 0 0 auto;
    color: var(--muted);
    font-size: 12px;
    font-weight: 800;
    line-height: 38px;
    text-transform: uppercase;
  }

  .post-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .post-card {
    display: grid;
    grid-template-rows: auto 1fr;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
    box-shadow: 0 8px 28px rgba(16, 32, 51, 0.045);
  }

  .post-card[hidden] {
    display: none;
  }

  .post-cover-link {
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--soft);
  }

  .post-cover-link img {
    width: 100%;
    height: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    transition: transform 0.28s ease;
  }

  .post-card:hover .post-cover-link img {
    transform: scale(1.025);
  }

  .post-card-body {
    display: grid;
    align-content: start;
    gap: 14px;
    padding: 22px;
  }

  .post-meta,
  .pill-row {
    flex-wrap: wrap;
    gap: 8px;
  }

  .post-meta span,
  .pill-row span {
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 5px 8px;
  }

  h3 {
    font-size: 24px;
    line-height: 1.12;
  }

  h3 a {
    text-decoration: none;
  }

  h3 a:hover {
    color: var(--blue);
  }

  .secondary-btn {
    width: fit-content;
    align-self: end;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 10px 14px;
    color: var(--ink);
    font-size: 14px;
    font-weight: 800;
    text-decoration: none;
  }

  .secondary-btn:hover {
    border-color: var(--blue);
    color: var(--blue);
  }

  .empty-state {
    display: grid;
    gap: 8px;
    border: 1px dashed var(--line);
    border-radius: 8px;
    background: var(--soft);
    padding: 28px;
  }

  .filter-empty {
    margin-top: 18px;
  }

  .filter-empty[hidden] {
    display: none;
  }

  .request-section .section-head {
    margin-bottom: 20px;
  }

  .filter-chip:focus-visible,
  .secondary-btn:focus-visible {
    outline: 3px solid rgba(11, 95, 181, 0.35);
    outline-offset: 2px;
  }

  @media (max-width: 980px) {
    .post-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 860px) {
    .header,
    .hero-grid {
      grid-template-columns: minmax(0, 1fr);
    }

    .header {
      display: grid;
    }

    .header nav {
      justify-content: flex-start;
    }

    .post-list {
      grid-template-columns: minmax(0, 1fr);
    }

    .filter-panel {
      display: grid;
      gap: 10px;
    }

    .filter-count {
      line-height: 1.4;
    }
  }
</style>
