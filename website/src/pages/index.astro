                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    {lucideIcons.mapPin.circles?.map(([cx, cy, r]) => <circle cx={cx} cy={cy} r={r} />)}
                    {lucideIcons.mapPin.paths?.map((path) => <path d={path} />)}
