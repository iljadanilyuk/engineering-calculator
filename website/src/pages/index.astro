</html>

<script>
  import {
    calculateEngineeringOffer,
    publicCalculatorConfigResponseSchema,
    projectExampleRequestSaveResponseSchema,
    type CalculationResult,
    type EngineeringService,
    type PublicProjectExampleRequestRecord,
    type ServiceRecord,
  } from '@poznyak-engineering-calculator/contracts'

  type ProjectType = 'private' | 'commercial'
  type CalculatorService = EngineeringService & { isPublic?: boolean }
  type CalculatorData = {
    defaultAreaSqm: string
    areaLimits: {
      min: number
      max: number
      step: number
    }
    exchangeRate: {
      source: 'manual' | 'nbrb' | 'fallback'
      usdToBynRate: string
      asOf?: string
    }
    fallbackServices: CalculatorService[]
    selectedServiceIds: string[]
    selectedProjectType: ProjectType
  }

  const dataElement = document.querySelector<HTMLScriptElement>('#calculator-data')
  const data = JSON.parse(dataElement?.textContent ?? '{}') as CalculatorData
  const areaInput = document.querySelector<HTMLInputElement>('[data-area-input]')
  const areaRange = document.querySelector<HTMLInputElement>('[data-area-range]')
  const areaError = document.querySelector<HTMLElement>('[data-area-error]')
  const serviceList = document.querySelector<HTMLElement>('[data-service-list]')
  const serviceEmpty = document.querySelector<HTMLElement>('[data-service-empty]')
  const serviceSource = document.querySelector<HTMLElement>('[data-service-source]')
  const totalByn = document.querySelector<HTMLElement>('[data-total-byn]')
  const summaryArea = document.querySelector<HTMLElement>('[data-summary-area]')
  const summaryList = document.querySelector<HTMLElement>('[data-summary-list]')
  const projectTypeButtons = [
    ...document.querySelectorAll<HTMLButtonElement>('[data-project-type]'),
  ]
  const offerLinks = [...document.querySelectorAll<HTMLAnchorElement>('[data-offer-link]')]
  const exampleForm = document.querySelector<HTMLFormElement>('[data-example-form]')
  const exampleNameInput = document.querySelector<HTMLInputElement>('[data-example-name]')
  const examplePhoneInput = document.querySelector<HTMLInputElement>('[data-example-phone]')
  const exampleConsent = document.querySelector<HTMLInputElement>('[data-example-consent]')
  const exampleChoices = [...document.querySelectorAll<HTMLInputElement>('[data-example-choice]')]
  const exampleChoiceError = document.querySelector<HTMLElement>('[data-example-choice-error]')
  const exampleNameError = document.querySelector<HTMLElement>('[data-example-name-error]')
  const examplePhoneError = document.querySelector<HTMLElement>('[data-example-phone-error]')
  const exampleConsentError = document.querySelector<HTMLElement>('[data-example-consent-error]')
  const exampleTrigger = document.querySelector<HTMLButtonElement>('[data-example-trigger]')
  const exampleStatus = document.querySelector<HTMLElement>('[data-example-status]')
  const exampleSuccess = document.querySelector<HTMLElement>('[data-example-success]')

  const numberFormatter = new Intl.NumberFormat('ru-RU')
  const supportedPricingTypes = new Set(['fixed', 'per_sqm'])
  const apiBaseUrl = (import.meta.env.PUBLIC_API_URL ?? '').trim().replace(/\/$/, '')
  const offerStateStorageKey = 'pzk-offer-choice-state-v1'

  let services = normalizeServices(data.fallbackServices)
  let selectedServiceIds = new Set(data.selectedServiceIds)
  let selectedProjectType: ProjectType = data.selectedProjectType ?? 'private'
  let currentCalculation: CalculationResult | null = null
  let isExampleSubmitting = false
  let exampleRequestIdempotencyKey = createIdempotencyKey()
  let hasUserChangedServices = false

  render()
  attachHandlers()
  void loadPublicConfig()

  function attachHandlers() {
    areaInput?.addEventListener('input', () => {
      const parsed = parseArea(areaInput.value)
      if (parsed.valid && areaRange) {
        const rangeValue = Math.min(
          Math.max(Number(parsed.canonical), data.areaLimits.min),
          data.areaLimits.max,
        )
        areaRange.value = String(rangeValue)
      }
      render()
    })

    areaRange?.addEventListener('input', () => {
      if (areaInput) areaInput.value = areaRange.value
      render()
    })

    projectTypeButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const nextType = button.dataset.projectType
        if (nextType !== 'private' && nextType !== 'commercial') return
        selectedProjectType = nextType
        updateProjectTypeButtons()
        updateOfferLink()
      })
    })

    offerLinks.forEach((offerLink) => {
      offerLink.addEventListener('click', () => {
        persistOfferChoiceState()
      })
    })

    document.querySelectorAll<HTMLButtonElement>('[data-example-select]').forEach((button) => {
      button.addEventListener('click', () => {
        const slug = button.dataset.exampleSlug
        if (!slug) return
        selectExampleForRequest(slug)
      })
    })

    exampleNameInput?.addEventListener('input', () => {
      validateExampleForm(false)
      resetExampleRequestState()
    })

    examplePhoneInput?.addEventListener('input', () => {
      validateExampleForm(false)
      resetExampleRequestState()
    })

    exampleConsent?.addEventListener('change', () => {
      validateExampleForm(false)
      resetExampleRequestState()
    })

    exampleChoices.forEach((choice) => {
      choice.addEventListener('change', () => {
        validateExampleForm(false)
        resetExampleRequestState()
        updateExampleSubmitState()
      })
    })

    exampleForm?.addEventListener('submit', (event) => {
      event.preventDefault()
      void submitExampleRequest()
    })

    document.querySelectorAll<HTMLButtonElement>('[data-faq-trigger]').forEach((button) => {
      button.addEventListener('click', () => {
        const answerId = button.getAttribute('aria-controls')
        const answer = answerId ? document.getElementById(answerId) : null
        const expanded = button.getAttribute('aria-expanded') === 'true'
        button.setAttribute('aria-expanded', String(!expanded))
        if (answer) answer.hidden = expanded
      })
    })

    updateProjectTypeButtons()
    updateExampleSubmitState()
  }

  async function loadPublicConfig() {
    if (!apiBaseUrl) {
      setSourceMessage('Базовые тарифы для предварительного расчета.')
      setExampleStatus('Выдача PDF-примеров требует подключенный backend API.')
      updateOfferLink()
      updateExampleSubmitState()
      return
    }

    try {
      const response = await fetch(`${apiBaseUrl}/api/public/calculator-config`, {
        headers: { Accept: 'application/json' },
      })

      if (!response.ok) throw new Error(`Calculator config request failed: ${response.status}`)

      const payload = publicCalculatorConfigResponseSchema.parse(await response.json())
      const publicServices = normalizeServices(payload.services)
      data.exchangeRate = payload.exchangeRate

      if (publicServices.length === 0) {
        services = []
        selectedServiceIds = new Set()
        setSourceMessage('Нет опубликованных услуг в API.')
      } else {
        services = publicServices
        reconcileSelectedServices(!hasUserChangedServices)
        setSourceMessage('Тарифы загружены из админ-панели.')
      }

      render()
    } catch (error) {
      services = normalizeServices(data.fallbackServices)
      reconcileSelectedServices(!hasUserChangedServices)
      setSourceMessage('API недоступен, показаны базовые тарифы.')
      if (error instanceof Error && error.message.includes('failed: 409')) {
        setExampleStatus('Калькулятор ждет настройку тарифа, но PDF-примеры можно запросить после контакта.')
      } else {
        setExampleStatus('API недоступен: PDF-примеры сейчас нельзя выдать по защищенной ссылке.', 'error')
      }
      render()
    }
  }

  function normalizeServices(source: Array<CalculatorService | ServiceRecord>): CalculatorService[] {
    return source
      .filter((service) => service.isActive && supportedPricingTypes.has(service.pricingType))
      .map((service) => ({
        id: service.id,
        title: service.title,
        description: service.description ?? null,
        pricingType: service.pricingType,
        priceUsdCents: service.priceUsdCents,
        isActive: service.isActive,
        sortOrder: service.sortOrder,
        pricingRule: service.pricingRule ?? undefined,
        formulaVersion: service.formulaVersion ?? undefined,
        createdAt: service.createdAt,
        updatedAt: service.updatedAt,
        isPublic: 'isPublic' in service ? service.isPublic : true,
      }))
      .sort((first, second) => first.sortOrder - second.sortOrder)
  }

  function render(focusServiceId?: string) {
    const parsedArea = parseArea(areaInput?.value ?? data.defaultAreaSqm)
    const canCalculate = parsedArea.valid && services.length > 0

    if (areaError) areaError.hidden = parsedArea.valid
    if (areaInput) {
      if (parsedArea.valid) {
        areaInput.removeAttribute('aria-invalid')
      } else {
        areaInput.setAttribute('aria-invalid', 'true')
      }
    }

    if (!canCalculate) {
      setCurrentCalculation(null)
      renderServices(focusServiceId, data.defaultAreaSqm)
      renderTotals(null)
      renderSummary(null)
      if (serviceEmpty) serviceEmpty.hidden = services.length > 0
      updateOfferLink()
      return
    }

    const calculation = calculateEngineeringOffer({
      areaSqm: parsedArea.canonical,
      selectedServiceIds: [...selectedServiceIds],
      services,
      exchangeRate: data.exchangeRate,
    })

    setCurrentCalculation(calculation)
    renderServices(focusServiceId, parsedArea.canonical)
    renderTotals(calculation)
    renderSummary(calculation)
    if (serviceEmpty) serviceEmpty.hidden = true
    updateOfferLink()
  }

  function renderServices(
    focusServiceId?: string,
    areaSqm = data.defaultAreaSqm,
  ) {
    if (!serviceList) return
    const allServiceRubles =
      services.length > 0 && parseArea(areaSqm).valid
        ? serviceRublesMap(
            calculateEngineeringOffer({
              areaSqm,
              selectedServiceIds: services.map((service) => service.id),
              services,
              exchangeRate: data.exchangeRate,
            }),
          )
        : new Map<string, number>()

    serviceList.innerHTML = services
      .map((service) => {
        const isSelected = selectedServiceIds.has(service.id)
        const buttonClass = isSelected ? 'service-row selected' : 'service-row'
        const lineRubles = allServiceRubles.get(service.id) ?? 0

        return `
          <button type="button" class="${buttonClass}" data-service-id="${escapeHtml(service.id)}" role="switch" aria-checked="${isSelected}">
            <span class="service-copy"><strong>${escapeHtml(service.title)}</strong><span>${escapeHtml(service.description ?? '')}</span></span>
            <span class="row-price"><strong>${formatRubles(lineRubles)} ${currencyMarkup()}</strong></span>
            <span class="toggle" aria-hidden="true"><span></span></span>
          </button>
        `
      })
      .join('')

    serviceList.querySelectorAll<HTMLButtonElement>('[data-service-id]').forEach((button) => {
      button.addEventListener('click', () => {
        const serviceId = button.dataset.serviceId
        if (!serviceId) return
        if (selectedServiceIds.has(serviceId)) {
          selectedServiceIds.delete(serviceId)
        } else {
          selectedServiceIds.add(serviceId)
        }
        hasUserChangedServices = true
        render(serviceId)
      })
    })

    if (focusServiceId) {
      const focusTarget = [...serviceList.querySelectorAll<HTMLButtonElement>('[data-service-id]')].find(
        (button) => button.dataset.serviceId === focusServiceId,
      )
      focusTarget?.focus()
    }
  }

  function renderTotals(calculation: CalculationResult | null) {
    if (totalByn) {
      totalByn.innerHTML = calculation
        ? `${formatRubles(calculation.totals.totalBynRoundedRubles)} ${currencyMarkup()}`
        : `0 ${currencyMarkup()}`
    }
  }

  function renderSummary(calculation: CalculationResult | null) {
    if (!summaryList) return

    if (summaryArea) {
      summaryArea.textContent = calculation ? compactArea(calculation.areaSqm) : data.defaultAreaSqm
    }

    if (!calculation || calculation.lineItems.length === 0) {
      summaryList.innerHTML = `<div class="summary-row muted"><span>Разделы не выбраны</span><strong>0 ${currencyMarkup()}</strong></div>`
      return
    }

    const displayRubles = allocateDisplayBynRubles(calculation)

    summaryList.innerHTML = calculation.lineItems
      .map(
        (lineItem) => `
          <div class="summary-row" data-summary-service-id="${escapeHtml(lineItem.serviceId)}">
            <span>${escapeHtml(lineItem.serviceSnapshot.title)}</span>
            <strong>${formatRubles(displayRubles.get(lineItem.serviceId) ?? 0)} ${currencyMarkup()}</strong>
          </div>
        `,
      )
      .join('')
  }

  function setCurrentCalculation(calculation: CalculationResult | null) {
    currentCalculation = calculation

    updateOfferLink()
  }

  async function submitExampleRequest() {
    if (isExampleSubmitting) return

    const validation = validateExampleForm(true)

    if (!validation.valid) {
      setExampleStatus('Проверьте поля формы перед отправкой.', 'error')
      return
    }

    if (!apiBaseUrl) {
      setExampleStatus('Выдача PDF недоступна: backend API сейчас не подключен.', 'error')
      return
    }

    isExampleSubmitting = true
    updateExampleSubmitState()
    setExampleStatus('Сохраняю контакт и готовлю ссылки на PDF-примеры...', 'loading')

    try {
      const response = await fetch(`${apiBaseUrl}/api/public/project-example-requests`, {
        method: 'POST',
        headers: {
          Accept: 'application/json',
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          idempotencyKey: exampleRequestIdempotencyKey,
          clientName: validation.clientName,
          clientPhone: validation.clientPhone,
          requestedExampleSlugs: validation.requestedExampleSlugs,
          consentAccepted: true,
          source: 'example_request',
          referrer: document.referrer || undefined,
          utm: readAttributionMetadata(),
        }),
      })
      const payload = await response.json().catch(() => null)

      if (!response.ok) {
        applyExampleServerValidationErrors(payload)
        throw new Error(exampleRequestErrorMessage(response.status, payload))
      }

      const parsed = projectExampleRequestSaveResponseSchema.parse(payload)
      showExampleSuccess(parsed.request, response.status === 200)
    } catch (error) {
      setExampleStatus(
        error instanceof Error ? error.message : 'Не удалось выдать PDF-примеры. Попробуйте еще раз.',
        'error',
      )
    } finally {
      isExampleSubmitting = false
      updateExampleSubmitState()
    }
  }

  function validateExampleForm(showErrors: boolean) {
    const clientName = exampleNameInput?.value.trim() ?? ''
    const clientPhone = examplePhoneInput?.value.trim() ?? ''
    const phoneDigits = clientPhone.replace(/\D/g, '')
    const requestedExampleSlugs = selectedExampleSlugs()
    const examplesValid = requestedExampleSlugs.length > 0
    const nameValid = clientName.length >= 2 && clientName.length <= 120
    const phoneValid =
      /^[+\d\s().-]{5,40}$/.test(clientPhone) &&
      phoneDigits.length >= 8 &&
      phoneDigits.length <= 15 &&
      !/^(\d)\1+$/.test(phoneDigits)
    const consentValid = exampleConsent?.checked === true

    if (exampleChoiceError) {
      exampleChoiceError.hidden = examplesValid || !showErrors
    }
    setFieldValidity(exampleNameInput, exampleNameError, nameValid, showErrors)
    setFieldValidity(examplePhoneInput, examplePhoneError, phoneValid, showErrors)
    setFieldValidity(exampleConsent, exampleConsentError, consentValid, showErrors)

    return {
      valid: examplesValid && nameValid && phoneValid && consentValid,
      clientName,
      clientPhone,
      requestedExampleSlugs,
    }
  }

  function setFieldValidity(
    input: HTMLInputElement | null,
    errorElement: HTMLElement | null,
    isValid: boolean,
    showError: boolean,
  ) {
    if (input) {
      if (isValid) {
        input.removeAttribute('aria-invalid')
      } else {
        input.setAttribute('aria-invalid', 'true')
      }
    }

    if (errorElement) {
      errorElement.hidden = isValid || !showError
    }
  }

  function updateExampleSubmitState() {
    if (!exampleTrigger) return

    const unavailable = isExampleSubmitting || !apiBaseUrl || selectedExampleSlugs().length === 0
    exampleTrigger.disabled = unavailable
    exampleTrigger.textContent = isExampleSubmitting ? 'Готовлю ссылки...' : 'Получить PDF-примеры'
  }

  function selectExampleForRequest(slug: string) {
    exampleChoices.forEach((choice) => {
      choice.checked = choice.value === slug
    })
    resetExampleRequestState()
    updateExampleSubmitState()
    exampleForm?.scrollIntoView({ behavior: 'smooth', block: 'center' })
    exampleNameInput?.focus({ preventScroll: true })
    setExampleStatus('Оставьте контакт: выбранный PDF откроется здесь по защищенной ссылке.')
  }

  function showExampleSuccess(
    request: PublicProjectExampleRequestRecord,
    returnedExisting: boolean,
  ) {
    if (exampleSuccess) {
      exampleSuccess.hidden = false
      exampleSuccess.innerHTML = `
        <strong>${returnedExisting ? 'Этот запрос уже сохранен' : 'Контакт сохранен'}</strong>
        <span>Телефон сохранен как ${escapeHtml(request.clientPhone)}.</span>
        <span>PDF-ссылки защищены token-адресом и не публикуются на странице.</span>
        <div class="proposal-actions">
          ${request.requestedExamples
            .map(
              (example) => `
                <a
                  class="proposal-link"
                  href="${apiBaseUrl}${escapeHtml(example.urlPath)}"
                  target="_blank"
                  rel="noopener"
                >
                  ${escapeHtml(example.code)} · ${escapeHtml(example.fileName)}
                </a>
              `,
            )
            .join('')}
        </div>
      `
    }

    setExampleStatus(
      returnedExisting
        ? 'Повторная отправка распознана: новая дубль-заявка не создана.'
        : 'Запрос принят. PDF-примеры готовы по защищенным ссылкам.',
      'ready',
    )
  }

  function hideExampleSuccess() {
    if (!exampleSuccess) return
    exampleSuccess.hidden = true
    exampleSuccess.innerHTML = ''
  }

  function resetExampleRequestState() {
    exampleRequestIdempotencyKey = createIdempotencyKey()
    hideExampleSuccess()
  }

  function persistOfferChoiceState() {
    if (!currentCalculation) return

    try {
      sessionStorage.setItem(
        offerStateStorageKey,
        JSON.stringify({
          areaSqm: currentCalculation.areaSqm,
          selectedServiceIds: currentCalculation.selectedServiceIds,
          projectType: selectedProjectType,
          savedAt: new Date().toISOString(),
        }),
      )
    } catch {
      // Session storage is only a convenience; URL parameters carry the state too.
    }
  }

  function applyExampleServerValidationErrors(payload: unknown) {
    if (!payload || typeof payload !== 'object' || !('error' in payload)) return
    const details = (payload as { error?: { details?: unknown } }).error?.details
    if (!Array.isArray(details)) return

    const phoneIssue = details.find((issue) =>
      Array.isArray((issue as { path?: unknown }).path)
        ? ((issue as { path: unknown[] }).path ?? []).includes('clientPhone')
        : false,
    )

    if (phoneIssue) {
      setFieldValidity(examplePhoneInput, examplePhoneError, false, true)
    }
  }

  function exampleRequestErrorMessage(status: number, payload: unknown) {
    const serverMessage =
      payload && typeof payload === 'object' && 'error' in payload
        ? (payload as { error?: { message?: string } }).error?.message
        : undefined

    if (status === 400) return serverMessage ?? 'Проверьте имя, телефон и согласие.'
    if (status === 409) return 'Выбранный пример временно недоступен. Обновите страницу и попробуйте еще раз.'
    if (status === 429) return 'Слишком много отправок подряд. Попробуйте немного позже.'
    return serverMessage ?? 'Не удалось выдать PDF-примеры. Попробуйте еще раз.'
  }

  function selectedExampleSlugs() {
    return exampleChoices
      .filter((choice) => choice.checked)
      .map((choice) => choice.value)
  }

  function readAttributionMetadata() {
    const searchParams = new URLSearchParams(window.location.search)
    const metadata: Record<string, string> = {}

    searchParams.forEach((value, key) => {
      if (!/^(utm_[a-z0-9_]+|gclid|yclid|fbclid)$/i.test(key)) return
      const trimmedValue = value.trim()
      if (!trimmedValue) return
      metadata[key.slice(0, 64)] = trimmedValue.slice(0, 500)
    })

    return Object.keys(metadata).length > 0 ? metadata : undefined
  }

  function createIdempotencyKey() {
    if ('randomUUID' in crypto) {
      return crypto.randomUUID()
    }

    return `${Date.now().toString(36)}${Math.random().toString(36).slice(2, 18)}`
  }

  function setExampleStatus(message: string, state?: 'ready' | 'error' | 'loading') {
    if (!exampleStatus) return
    exampleStatus.textContent = message
    exampleStatus.classList.toggle('is-ready', state === 'ready')
    exampleStatus.classList.toggle('is-error', state === 'error')
    exampleStatus.classList.toggle('is-loading', state === 'loading')
  }

  function parseArea(value: string) {
    const canonical = value.trim().replace(',', '.')

    if (!/^(?:0|[1-9]\d{0,7})(?:\.\d{1,2})?$/.test(canonical)) {
      return { valid: false, canonical: data.defaultAreaSqm }
    }

    const numericValue = Number(canonical)
    if (numericValue < data.areaLimits.min || numericValue > data.areaLimits.max) {
      return { valid: false, canonical: data.defaultAreaSqm }
    }

    return { valid: true, canonical }
  }

  function setSourceMessage(message: string) {
    if (serviceSource) serviceSource.textContent = message
  }

  function updateProjectTypeButtons() {
    projectTypeButtons.forEach((button) => {
      const isSelected = button.dataset.projectType === selectedProjectType
      button.classList.toggle('active', isSelected)
      button.setAttribute('aria-pressed', String(isSelected))
    })
  }

  function updateOfferLink() {
    if (offerLinks.length === 0) return

    const params = new URLSearchParams()
    const areaSqm = currentCalculation?.areaSqm ?? parseArea(areaInput?.value ?? data.defaultAreaSqm).canonical
    const serviceIds = currentCalculation?.selectedServiceIds ?? [...selectedServiceIds]
    params.set('area', areaSqm)
    params.set('type', selectedProjectType)
    params.set('services', serviceIds.join(','))
    const attribution = readAttributionMetadata()
    if (attribution) {
      Object.entries(attribution).forEach(([key, value]) => {
        params.set(key, value)
      })
    }

    const href = `/offer/?${params.toString()}`
    offerLinks.forEach((offerLink) => {
      offerLink.href = href
    })
  }

  function defaultSelectedServiceIds(source: CalculatorService[]) {
    return source.slice(0, Math.min(3, source.length)).map((service) => service.id)
  }

  function reconcileSelectedServices(fallbackToDefaults: boolean) {
    const availableServiceIds = new Set(services.map((service) => service.id))
    const validSelectedServiceIds = [...selectedServiceIds].filter((serviceId) =>
      availableServiceIds.has(serviceId),
    )

    selectedServiceIds = new Set(
      validSelectedServiceIds.length > 0 || !fallbackToDefaults
        ? validSelectedServiceIds
        : defaultSelectedServiceIds(services),
    )
  }

  function formatRubles(value: number) {
    return numberFormatter.format(value)
  }

  function compactArea(value: string) {
    return value.replace(/\.0+$/, '').replace(/(\.\d*[1-9])0+$/, '$1')
  }

  function currencyMarkup() {
    return '<img class="currency-symbol" src="/landing-v4/byn-symbol.svg" alt="" aria-hidden="true"><span class="sr-only"> BYN</span>'
  }

  function allocateDisplayBynRubles(calculation: CalculationResult) {
    const floorRows = calculation.lineItems.map((lineItem, index) => ({
      serviceId: lineItem.serviceId,
      rubles: Math.floor(lineItem.totalBynCents / 100),
      remainder: lineItem.totalBynCents % 100,
      index,
    }))
    const floorTotal = floorRows.reduce((total, row) => total + row.rubles, 0)
    const remainingRubles = calculation.totals.totalBynRoundedRubles - floorTotal
    const rowsByRemainder = [...floorRows].sort(
      (first, second) => second.remainder - first.remainder || first.index - second.index,
    )

    for (const row of rowsByRemainder.slice(0, Math.max(0, remainingRubles))) {
      row.rubles += 1
    }

    return new Map(rowsByRemainder.map((row) => [row.serviceId, row.rubles]))
  }

  function serviceRublesMap(calculation: CalculationResult) {
    return new Map(
      calculation.lineItems.map((lineItem) => [lineItem.serviceId, lineItem.totalBynRoundedRubles]),
    )
  }

  function escapeHtml(value: string) {
    return value
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;')
  }
</script>

