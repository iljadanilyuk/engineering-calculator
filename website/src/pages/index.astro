                    {lucideIcons.phone.paths?.map((path) => <path d={path} />)}
                  </svg>
                  <span>{contactPhone || 'Телефон будет указан после подтверждения владельца'}</span>
                </div>
                <div class="contact-row">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    {
                      lucideIcons.mail.rects?.map((rect) => (
                        <rect
                          x={rect.x}
                          y={rect.y}
                          width={rect.width}
                          height={rect.height}
                          rx={rect.rx ?? 0}
                        />
                      ))
                    }
                    {lucideIcons.mail.paths?.map((path) => <path d={path} />)}
                  </svg>
                  <span>{contactEmail || 'Контактный email указывается перед публикацией'}</span>
                </div>
