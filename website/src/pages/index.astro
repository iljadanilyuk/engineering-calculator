    align-items: start;
  }

  .calculator-panel {
    min-width: 0;
    padding: 34px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: #ffffff;
    box-shadow: var(--shadow);
  }

  .field-label {
    display: block;
    margin-bottom: 9px;
    font-size: 14px;
    font-weight: 750;
  }

  .area-input-wrap {
    width: 210px;
    position: relative;
  }

  .area-input {
    width: 100%;
    height: 66px;
    border: 1px solid var(--line-strong);
    border-radius: 8px;
    background: #ffffff;
    padding: 0 54px 0 20px;
    color: var(--ink);
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 800;
  }

  .area-input[aria-invalid] {
    border-color: var(--danger);
  }

  .area-unit {
    position: absolute;
    right: 17px;
    top: 50%;
    color: var(--muted);
    font-weight: 700;
    transform: translateY(-50%);
  }

  .area-range {
    width: 100%;
    margin-top: 18px;
    accent-color: var(--blue);
  }

  .range-labels {
    display: flex;
    justify-content: space-between;
    margin-top: 5px;
    color: var(--muted);
    font-size: 11px;
  }

  .field-help,
  .field-error {
    margin-top: 10px;
    color: var(--muted);
    font-size: 13px;
  }

  .field-error {
    color: var(--danger);
    font-weight: 700;
  }

  .type-block {
    margin-top: 32px;
  }

  .type-switch {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 18px;
  }

  .type-button {
    min-height: 62px;
    display: flex;
    align-items: center;
    gap: 13px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #ffffff;
    color: var(--ink);
    padding: 0 20px;
    font-weight: 750;
    text-align: left;
  }

  .type-button svg {
    width: 26px;
    height: 26px;
    flex: 0 0 26px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.7;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .type-button.active {
    border-color: var(--blue);
    background: var(--selected);
    color: var(--blue);
    box-shadow: 0 0 0 1px rgba(11, 95, 181, 0.08);
  }

  .services-head {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    margin-top: 32px;
    margin-bottom: 12px;
  }

  .services-head strong {
    font-size: 16px;
  }

  .services-head span {
    color: var(--muted);
    font-size: 12px;
  }

  .services {
    display: grid;
  }

  .service-row {
    width: 100%;
    min-height: 56px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 90px 42px;
    align-items: center;
    gap: 16px;
    border: 0;
    border-top: 1px solid var(--line);
    background: transparent;
    padding: 9px 0;
    color: inherit;
    text-align: left;
  }

  .service-row.selected {
    background: var(--selected);
    margin-inline: -12px;
    padding-inline: 12px;
    border-radius: 8px;
  }

  .service-copy {
    min-width: 0;
  }

  .service-copy strong,
  .service-copy span {
    display: block;
  }

  .service-copy strong {
    overflow-wrap: anywhere;
    font-size: 14px;
    font-weight: 800;
  }

  .service-copy span {
    margin-top: 1px;
    color: var(--muted);
    font-size: 11px;
  }

  .row-price {
    text-align: right;
  }

  .row-price strong {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    gap: 4px;
    color: var(--ink);
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 800;
    white-space: nowrap;
  }

  .currency-symbol {
    width: 0.72em;
    height: 0.72em;
    display: inline-block;
    object-fit: contain;
    vertical-align: -0.04em;
  }

  .toggle {
    width: 38px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    border: 1px solid #c8d2dc;
    border-radius: 999px;
    background: #d4dbe2;
    padding: 2px;
    transition: 0.16s ease;
  }

  .toggle span {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #ffffff;
    box-shadow: 0 1px 4px rgba(16, 32, 51, 0.22);
    transition: 0.16s ease;
  }

  .selected .toggle {
    justify-content: flex-end;
    border-color: var(--blue);
    background: var(--blue);
  }

  .service-empty {
    border: 1px dashed var(--line);
    border-radius: 8px;
    background: var(--paper);
    padding: 18px;
    color: var(--body);
    font-weight: 700;
  }

  .calc-footnote {
    margin-top: 18px;
    color: var(--muted);
    font-size: 12px;
  }

  .result-card {
    position: sticky;
    top: 96px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: #ffffff;
    padding: 28px;
    box-shadow: var(--shadow);
  }

  .result-card h3 {
    color: var(--blue);
    font-size: 14px;
    margin-bottom: 18px;
  }

  .selected-list {
    display: grid;
    gap: 12px;
  }

  .summary-row {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    color: var(--body);
    font-size: 13px;
  }

  .summary-row strong {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--ink);
    font-family: var(--font-heading);
    font-weight: 800;
    white-space: nowrap;
  }

  .summary-row.muted {
    color: var(--muted);
  }

  .area-summary {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    margin-top: 26px;
    border-top: 1px solid var(--line);
    padding-top: 22px;
    color: var(--body);
    font-size: 14px;
  }

  .area-summary strong {
    color: var(--ink);
    font-family: var(--font-heading);
    font-weight: 800;
  }

  .total-box {
    margin-top: 28px;
    border-radius: 12px;
    background: linear-gradient(135deg, #f7f9fc, #eef3f8);
    padding: 28px 24px;
  }

  .total-label {
    color: var(--body);
    font-size: 14px;
    font-weight: 700;
  }

  .total {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-top: 7px;
    font-family: var(--font-heading);
    font-size: clamp(34px, 4vw, 42px);
    line-height: 1;
    font-weight: 800;
  }

  .total .currency-symbol {
    width: 0.62em;
    height: 0.62em;
  }

  .result-cta {
    width: 100%;
    margin-top: 20px;
  }

  .result-note {
    margin-top: 18px;
    color: var(--muted);
    font-size: 12px;
    text-align: center;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 36px;
    align-items: start;
  }

  .benefit {
    display: grid;
    justify-items: center;
    gap: 14px;
    text-align: center;
  }

  .benefit svg {
    width: 62px;
    height: 62px;
    border: 1px solid rgba(11, 95, 181, 0.18);
    border-radius: 16px;
    padding: 15px;
    background: linear-gradient(180deg, #ffffff, #f3f8fd);
    box-shadow: 0 12px 28px rgba(11, 95, 181, 0.08);
    fill: none;
    stroke: var(--blue);
    stroke-width: 1.85;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .benefit strong {
    max-width: 190px;
    font-size: 14px;
    line-height: 1.38;
  }

  .docs-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 22px;
  }

  .doc-card {
    min-width: 0;
  }

  .doc-image {
    width: 100%;
    aspect-ratio: 1.43;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #ffffff;
    object-fit: cover;
    object-position: center;
  }

  .doc-body {
    padding: 14px 8px 0;
  }

  .doc-body strong {
    color: var(--blue);
    font-size: 15px;
  }

  .doc-body p {
    margin-top: 7px;
    color: var(--body);
    font-size: 13px;
    line-height: 1.5;
  }

  .text-button {
    margin-top: 10px;
    border: 0;
    background: transparent;
    color: var(--blue);
    padding: 0;
    font-weight: 800;
    text-align: left;
  }

  .example-request-form {
    display: grid;
    grid-template-columns: minmax(230px, 0.78fr) minmax(320px, 1fr) minmax(430px, 1.22fr);
    gap: 28px;
    align-items: stretch;
    margin-top: 34px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: #ffffff;
    padding: 26px;
    box-shadow: 0 18px 42px rgba(16, 32, 51, 0.07);
  }

  .example-form-copy {
    display: grid;
    align-content: start;
    gap: 10px;
    border-right: 1px solid var(--line);
    padding-right: 26px;
  }

  .example-form-copy strong {
    color: var(--ink);
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 800;
    line-height: 1.18;
  }

  .example-form-copy span,
  .example-request-form p,
  .lead-form p {
    color: var(--muted);
    font-size: 12px;
    font-weight: 650;
  }

  .example-choice-group {
    display: grid;
    align-content: start;
    gap: 10px;
    margin: 0;
    border: 0;
    padding: 0;
  }

  .example-choice-group legend,
  .example-request-form label span,
  .lead-form label span {
    margin-bottom: 7px;
    color: var(--muted);
    font-size: 12px;
    font-weight: 800;
  }

  .example-choice {
    display: grid;
    grid-template-columns: 20px 40px minmax(0, 1fr);
    align-items: center;
    gap: 11px;
    min-height: 48px;
    border: 1px solid rgba(219, 227, 235, 0.85);
    border-radius: 10px;
    background: #f8fbfe;
    padding: 9px 11px;
  }

  .example-choice input,
  .consent-row input {
    width: 18px;
    height: 18px;
    accent-color: var(--blue);
  }

  .example-choice span {
    display: inline-grid;
    place-items: center;
    width: 36px;
    min-height: 26px;
    border-radius: 999px;
    background: #e7f1fb;
    color: var(--blue);
    font-family: var(--font-heading);
    font-size: 12px;
    font-weight: 800;
  }

  .example-choice strong {
    min-width: 0;
    font-size: 13px;
    line-height: 1.3;
  }

  .example-fields {
    min-width: 0;
    display: grid;
    align-content: start;
    gap: 13px;
  }

  .example-input-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .example-request-form label,
  .lead-form label {
    display: grid;
    gap: 5px;
  }

  .example-request-form input:not([type="checkbox"]),
  .lead-form input:not([type="checkbox"]),
  .lead-form textarea {
    width: 100%;
    min-height: 52px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #ffffff;
    padding: 0 16px;
  }

  .lead-form textarea {
    min-height: 98px;
    padding: 12px 14px;
    resize: vertical;
  }

  .example-request-form input[aria-invalid],
  .lead-form input[aria-invalid] {
    border-color: var(--danger);
    background: #fff8f4;
  }

  .consent-row {
    display: grid;
    grid-template-columns: 18px minmax(0, 1fr);
    align-items: start;
    gap: 11px;
    border: 1px solid rgba(219, 227, 235, 0.85);
    border-radius: 10px;
    background: #f8fbfe;
    padding: 11px 12px;
  }

  .consent-row input {
    margin: 1px 0 0;
  }

  .consent-row span {
    color: var(--body);
    font-size: 12px;
    line-height: 1.35;
  }

  .example-action-row {
    display: grid;
    grid-template-columns: minmax(240px, 0.78fr) minmax(0, 1fr);
    gap: 14px;
    align-items: center;
    margin-top: 2px;
  }

  .example-action-row .button {
    min-height: 52px;
    width: 100%;
    white-space: nowrap;
  }

  .example-action-row p {
    border-radius: 10px;
    background: #eef5fb;
    padding: 11px 12px;
  }

  .lead-success {
    display: grid;
    gap: 5px;
    border: 1px solid rgba(11, 95, 181, 0.22);
    border-radius: 10px;
    background: #eef5fb;
    padding: 12px;
    color: var(--body);
    font-size: 12px;
    font-weight: 700;
  }

  .lead-success strong,
  .lead-success span {
    display: block;
  }

  .lead-success strong {
    color: var(--navy);
    font-size: 13px;
  }

  .lead-success .currency-symbol {
    width: 0.7em;
    height: 0.7em;
  }

  .proposal-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 14px;
  }

  .proposal-link {
    width: fit-content;
    border-bottom: 1px solid var(--blue);
    color: var(--blue);
    font-weight: 800;
  }

  .process {
    position: relative;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 30px;
  }

  .process::before {
    content: "";
    position: absolute;
    top: 15px;
    left: 7%;
    right: 7%;
    height: 1px;
    background: var(--line-strong);
  }

  .step {
    position: relative;
    display: grid;
    gap: 10px;
    align-content: start;
  }

  .step-number {
    width: 30px;
    height: 30px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--blue);
    color: #ffffff;
    font-family: var(--font-heading);
    font-size: 11px;
    font-weight: 800;
  }

  .step-icon {
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border: 1px solid rgba(11, 95, 181, 0.18);
    border-radius: 12px;
    color: var(--blue);
    background: linear-gradient(180deg, #ffffff, #f3f8fd);
    box-shadow: 0 10px 24px rgba(11, 95, 181, 0.08);
  }

  .step-icon svg {
    width: 24px;
    height: 24px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.85;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .step strong {
    font-size: 15px;
  }

  .step p {
    color: var(--body);
    font-size: 13px;
    line-height: 1.5;
  }

  .faq-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px 24px;
  }

  .faq-item h3 {
    margin: 0;
  }

  .faq-question {
    width: 100%;
    min-height: 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: #ffffff;
    color: var(--ink);
    padding: 0 18px;
    font-size: 14px;
    font-weight: 700;
    text-align: left;
  }

  .faq-question span:last-child {
    color: var(--blue);
    font-size: 18px;
    transition: transform 0.16s ease;
  }

  .faq-question[aria-expanded="true"] span:last-child {
    transform: rotate(180deg);
  }

  .faq-answer {
    border: 1px solid var(--line);
    border-top: 0;
    border-radius: 0 0 8px 8px;
    background: #ffffff;
    padding: 14px 18px 18px;
    color: var(--body);
    font-size: 13px;
    line-height: 1.55;
  }

  .cta-section {
    background: var(--navy);
    color: #ffffff;
    padding: 72px 0 0;
  }

  .cta-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 380px) minmax(240px, 310px);
    gap: 52px;
    align-items: start;
  }

  .cta-copy h2 {
    max-width: 480px;
    font-size: clamp(30px, 3vw, 40px);
    line-height: 1.1;
  }

  .cta-copy p {
    max-width: 520px;
    margin-top: 16px;
    color: rgba(255, 255, 255, 0.72);
    font-size: 16px;
  }

  .cta-facts {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
    margin-top: 46px;
  }

  .cta-fact {
    color: rgba(255, 255, 255, 0.7);
    font-size: 12px;
  }

  .cta-fact strong,
  .cta-fact span {
    display: block;
  }

  .cta-fact strong {
    margin-bottom: 4px;
    color: #ffffff;
    font-size: 13px;
  }

  .lead-form {
    display: grid;
    gap: 10px;
    border-radius: 12px;
    background: #ffffff;
    padding: 20px;
    color: var(--ink);
    box-shadow: 0 24px 58px rgba(0, 0, 0, 0.22);
  }

  .lead-choice-card {
    align-content: start;
    gap: 16px;
  }

  .lead-choice-card > strong {
    color: var(--blue);
    font-family: var(--font-heading);
    font-size: 22px;
    line-height: 1.15;
  }

  .lead-choice-card > p {
    color: var(--body);
    font-size: 13px;
    font-weight: 650;
  }

  .lead-choice-actions {
    display: grid;
    gap: 12px;
    justify-items: start;
  }

  .lead-form .button {
    width: 100%;
  }

  .lead-form p.is-ready,
  .example-request-form p.is-ready {
    color: var(--success);
  }

  .lead-form p.is-error,
  .example-request-form p.is-error {
    color: var(--danger);
  }

  .lead-form p.is-loading,
  .example-request-form p.is-loading {
    color: var(--blue);
  }

  .privacy-note {
    border-top: 1px solid var(--line);
    padding-top: 10px;
  }

  .contacts h3 {
    font-size: 24px;
  }

  .contact-list {
    display: grid;
    gap: 15px;
    margin-top: 20px;
  }

  .contact-row {
    display: flex;
    gap: 11px;
    align-items: flex-start;
    color: rgba(255, 255, 255, 0.82);
    font-size: 14px;
  }

  .contact-row svg {
    width: 18px;
    height: 18px;
    flex: 0 0 18px;
    fill: none;
    stroke: #9bbfe3;
    stroke-width: 1.8;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .contacts-note {
    margin-top: 30px;
    color: rgba(255, 255, 255, 0.62);
    font-size: 14px;
  }

  .footer {
    min-height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    margin-top: 54px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.6);
    font-size: 12px;
  }

  .service-row:focus-visible,
  .type-button:focus-visible,
  .button:focus-visible,
  .top-cta:focus-visible,
  .text-button:focus-visible,
  .faq-question:focus-visible,
  input:focus-visible,
  textarea:focus-visible {
    outline: 3px solid rgba(11, 95, 181, 0.35);
    outline-offset: 2px;
  }

  @media (max-width: 1100px) {
    .header-inner {
      grid-template-columns: 240px 1fr;
    }

    .nav {
      display: none;
    }

    .top-cta {
      justify-self: end;
    }

    .calculator-layout,
    .cta-grid {
      grid-template-columns: 1fr;
    }

    .result-card {
      position: static;
    }

    .benefits-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .docs-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .example-request-form {
      grid-template-columns: 1fr;
    }

    .example-form-copy {
      border-right: 0;
      border-bottom: 1px solid var(--line);
      padding-right: 0;
      padding-bottom: 22px;
    }

    .process {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .process::before {
      display: none;
    }
  }

  @media (max-width: 760px) {
    .shell {
      width: min(100% - 28px, var(--shell));
    }

    .header-inner {
      min-height: 66px;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 14px;
    }

    .brand-copy strong {
      font-size: 16px;
    }

    .brand-copy > span {
      max-width: 150px;
      font-size: 10px;
      line-height: 1.25;
    }

    .brand-mark {
      width: 38px;
      height: 38px;
      flex-basis: 38px;
    }

    .top-cta {
      min-height: 38px;
      padding: 0 13px;
      font-size: 12px;
    }

    .hero-grid {
      min-height: 0;
      display: flex;
      flex-direction: column;
    }

    .hero-copy {
      padding: 28px 0 18px;
    }

    h1 {
      font-size: clamp(26px, 8vw, 32px);
    }

    .hero-text {
      font-size: 16px;
    }

    .hero-image {
      height: auto;
      min-height: 0;
      margin: 0 -14px;
      border-top: 1px solid var(--line);
    }

    .hero-image::before {
      display: none;
    }

    .hero-image img {
      min-height: 0;
      aspect-ratio: 1.68;
