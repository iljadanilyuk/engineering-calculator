    color-scheme: light;
    --navy: #081a2f;
    --blue: #0a5ea8;
    --blue-2: #084777;
    --blue-soft: #eaf4fb;
    --ink: #102033;
    --body: #4d5b6a;
    --muted: #7a8794;
    --line: #dbe3eb;
    --line-strong: #c5d0db;
    --paper: #f6f8fb;
    --surface: #ffffff;
    --danger: #b6401a;
    --success: #0b5f46;
    --shadow: 0 18px 50px rgba(16, 32, 51, 0.1);
    --shell: 1160px;
    --font-body: "IBM Plex Sans", "Segoe UI", Arial, sans-serif;
    --font-heading: "IBM Plex Mono", "IBM Plex Sans", "Segoe UI", Arial, sans-serif;
  }

  * {
