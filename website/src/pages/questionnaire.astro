---
import {
  QUESTIONNAIRE_VERSION,
  calculateEngineeringOffer,
  technicalQuestionnaireDefinition,
  type CalculationResult,
} from '@poznyak-engineering-calculator/contracts'
import {
  areaLimits,
  defaultAreaSqm,
  defaultSelectedServiceIds,
  exchangeRate,
  fallbackServices,
} from '../lib/public-calculator'
import { createPageMeta, serializeJsonLd, siteName } from '../lib/seo'
import PublicFontLinks from '../components/PublicFontLinks.astro'
import SiteHeader from '../components/SiteHeader.astro'

const initialCalculation = calculateEngineeringOffer({
  areaSqm: defaultAreaSqm,
  selectedServiceIds: defaultSelectedServiceIds,
  services: fallbackServices,
  exchangeRate,
})

const questionnaireData = {
  version: QUESTIONNAIRE_VERSION,
  definition: technicalQuestionnaireDefinition,
  defaultAreaSqm,
  areaLimits,
  exchangeRate,
  fallbackServices,
  selectedServiceIds: defaultSelectedServiceIds,
  selectedProjectType: 'private',
}

const formatRubles = (value: number) => new Intl.NumberFormat('ru-RU').format(value)

const pageMeta = createPageMeta({
  siteUrl: import.meta.env.PUBLIC_WEBSITE_URL,
  path: '/questionnaire/',
  title: 'Подробный опросник для ТЗ - ИП Позняк',
  description:
    'Пошаговый опросник по инженерным системам дома для подготовки технического задания.',
  robots: 'noindex,nofollow',
})

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  url: pageMeta.canonicalUrl,
  name: pageMeta.title,
  description: pageMeta.description,
  inLanguage: 'ru-BY',
  isPartOf: {
    '@id': `${pageMeta.siteUrl}/#website`,
  },
}

function allocateDisplayBynRubles(calculation: CalculationResult) {
  const floorRows = calculation.lineItems.map((lineItem, index) => ({
    serviceId: lineItem.serviceId,
    rubles: Math.floor(lineItem.totalBynCents / 100),
    remainder: lineItem.totalBynCents % 100,
    index,
  }))
  const floorTotal = floorRows.reduce((total, row) => total + row.rubles, 0)
  const remainingRubles = calculation.totals.totalBynRoundedRubles - floorTotal
  const rowsByRemainder = [...floorRows].sort(
    (first, second) => second.remainder - first.remainder || first.index - second.index,
  )

  for (const row of rowsByRemainder.slice(0, Math.max(0, remainingRubles))) {
    row.rubles += 1
  }

  return new Map(rowsByRemainder.map((row) => [row.serviceId, row.rubles]))
}

const initialSummaryRubles = allocateDisplayBynRubles(initialCalculation)
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <PublicFontLinks />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageMeta.title}</title>
    <meta name="description" content={pageMeta.description} />
    <meta name="robots" content={pageMeta.robots} />
    <link rel="canonical" href={pageMeta.canonicalUrl} />
    <meta property="og:locale" content="ru_BY" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageMeta.title} />
    <meta property="og:description" content={pageMeta.description} />
    <meta property="og:url" content={pageMeta.canonicalUrl} />
    <meta property="og:image" content={pageMeta.imageUrl} />
    <meta property="og:image:secure_url" content={pageMeta.imageUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={pageMeta.imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageMeta.title} />
    <meta name="twitter:description" content={pageMeta.description} />
    <meta name="twitter:image" content={pageMeta.imageUrl} />
    <meta name="twitter:image:alt" content={pageMeta.imageAlt} />
    <script type="application/ld+json" is:inline set:html={serializeJsonLd(structuredData)} />
    <script
      id="questionnaire-data"
      type="application/json"
      is:inline
      set:html={JSON.stringify(questionnaireData)}
    />
  </head>
  <body>
    <SiteHeader />

    <main class="questionnaire-page">
      <section class="questionnaire-intro shell" aria-labelledby="questionnaire-title">
        <div>
          <div class="eyebrow">Опросник</div>
          <h1 id="questionnaire-title">Подробный опросник для подготовки ТЗ</h1>
          <p>
            Заполняйте по шагам. Ответы помогут проектировщику учесть важные детали
            вашего дома. Если каких-то данных пока нет, вопрос можно пропустить и
            вернуться к нему позже.
          </p>
          <p class="state-status" data-config-status role="status" hidden></p>
        </div>

        <button
          class="request-chip"
          type="button"
          aria-controls="project-summary-drawer"
          aria-expanded="false"
          data-project-summary-open
        >
          <span class="request-chip-icon" aria-hidden="true">↗</span>
          <span>
            <small>Связано с заявкой</small>
            <strong>Опросник по расчету</strong>
            <em><span data-summary-area>{defaultAreaSqm}</span> м² · <span data-summary-type>Частный дом</span></em>
          </span>
        </button>
      </section>

      <section class="questionnaire-progress shell" aria-label="Общий прогресс опросника">
        <div class="progress-main">
          <div class="progress-heading">
            <strong data-progress-text>Опросник начнется после сохранения контакта.</strong>
            <span data-progress-percent>0%</span>
          </div>
          <progress data-progress-bar max="100" value="0">0%</progress>
          <div class="progress-note">
            <span>Ответы сохраняются автоматически. Можно продолжить позже.</span>
            <b data-current-section>Текущий раздел: контакты и объект</b>
          </div>
        </div>

        <aside class="project-context-card" aria-label="Кратко о проекте">
          <div class="project-context-head">
            <strong>Кратко о проекте</strong>
            <button
              class="text-button"
              type="button"
              aria-controls="project-summary-drawer"
              aria-expanded="false"
              data-project-summary-open
            >
              Подробнее
            </button>
          </div>
          <dl class="project-metrics">
            <div>
              <dt>Площадь</dt>
              <dd><span data-summary-area>{defaultAreaSqm}</span> м²</dd>
            </div>
            <div>
              <dt>Тип объекта</dt>
              <dd data-summary-type>Частный дом</dd>
            </div>
            <div>
              <dt>Ориентир</dt>
              <dd data-total-byn>
                {formatRubles(initialCalculation.totals.totalBynRoundedRubles)}
                <img class="currency-symbol" src="/landing-v4/byn-symbol.svg" alt="" aria-hidden="true" />
                <span class="sr-only"> BYN</span>
              </dd>
            </div>
          </dl>
        </aside>
      </section>

      <button
        class="mobile-section-select shell"
        type="button"
        aria-controls="section-drawer"
        aria-expanded="false"
        data-mobile-sections-open
      >
        <span>
          <small>Текущий раздел</small>
          <strong data-mobile-section-name>Контакты и объект</strong>
        </span>
        <b>Сменить раздел</b>
      </button>

      <section class="workspace" aria-labelledby="workspace-title">
        <div class="shell workspace-grid">
          <aside class="section-sidebar" aria-label="Разделы опросника">
            <div class="panel-head">
              <div>
                <div class="section-kicker">Разделы</div>
                <h2 id="workspace-title">Структура ТЗ</h2>
              </div>
            </div>
            <div class="section-nav" data-section-nav></div>
            <div class="manager-card">
              <strong>Нужна помощь?</strong>
              <p>Менеджер подскажет, какой вариант выбрать, если исходные данные пока неполные.</p>
            </div>
          </aside>

          <div class="question-stack">
            <form class="contact-gate" data-contact-form novalidate>
              <div class="panel-head">
                <div>
                  <div class="section-kicker">Старт</div>
                  <h2>Сохранить контакт</h2>
                </div>
              </div>
              <div class="contact-grid">
                <label for="questionnaire-name">
                  <span>Ваше имя</span>
                  <input id="questionnaire-name" data-client-name type="text" autocomplete="name" />
                </label>
                <label for="questionnaire-phone">
                  <span>Телефон</span>
                  <input
                    id="questionnaire-phone"
                    data-client-phone
                    type="tel"
                    inputmode="tel"
                    autocomplete="tel"
                    placeholder="+375 29 123-45-67"
                  />
                  <small class="field-error" data-phone-error hidden>
                    Введите телефон в формате +375 ... или +7 ...
                  </small>
                </label>
              </div>
              <label for="questionnaire-object">
                <span>Объект и задача</span>
                <textarea
                  id="questionnaire-object"
                  data-object-name
                  rows="3"
                  maxlength="160"
                  placeholder="Например: дом 180 м², отопление, ВК и вентиляция"
                ></textarea>
              </label>
              <label class="consent-row" for="questionnaire-consent">
                <input id="questionnaire-consent" data-consent type="checkbox" checked />
                <span>Согласен на обработку персональных данных и ответов опросника для подготовки ТЗ и обратной связи.</span>
              </label>
              <button class="button primary" type="submit" data-start-trigger>
                Начать подробный опросник
              </button>
            </form>

            <section class="stored-resume-panel" data-stored-resume-panel hidden aria-label="Продолжить опросник">
              <div>
                <div class="section-kicker">На этом устройстве</div>
                <h2>Есть начатый опросник</h2>
                <p>Можно продолжить с места остановки или начать новый сценарий после проверки контакта.</p>
              </div>
              <div class="resume-actions">
                <button class="button primary" type="button" data-stored-resume-continue>
                  Продолжить
                </button>
                <button class="button ghost" type="button" data-stored-resume-clear>
                  Заполнить заново
                </button>
              </div>
            </section>

            <section class="resume-panel" data-resume-panel hidden aria-label="Связь с заявкой">
              <div>
                <div class="section-kicker">Сохранено</div>
                <h2>Опросник привязан к заявке</h2>
                <p>
                  Площадь, тип объекта и выбранные услуги уже подставлены автоматически.
                  Повторно вводить эти данные не нужно.
                </p>
              </div>
            </section>

            <fieldset class="question-card" data-question-card hidden>
              <div class="question-topline">
                <p class="question-meta" data-question-meta></p>
                <span class="question-state" data-question-state>Не отвечен</span>
              </div>
              <legend data-question-title>Вопрос</legend>
              <p class="skipped-note" data-skipped-note hidden>
                Этот вопрос пропущен. Можно выбрать ответ сейчас или оставить уточнение для менеджера.
              </p>
              <div class="option-grid" data-option-list></div>
              <label class="custom-answer" for="custom-answer">
                <span data-custom-answer-label>Если нужно, уточните</span>
                <textarea
                  id="custom-answer"
                  data-custom-answer
                  rows="4"
                  maxlength="2000"
                  placeholder="Например: какие работы уже выполнены, какие решения еще можно изменить"
                ></textarea>
              </label>
              <div class="question-footer">
                <p class="wizard-status autosave-status" data-wizard-status role="status">
                  Ответы сохраняются автоматически
                </p>
                <div class="pager">
                  <button class="button secondary" type="button" data-prev-question>Назад</button>
                  <button class="button ghost" type="button" data-answer-skipped>
                    Пропустить
                  </button>
                  <button class="button primary" type="button" data-next-question>
                    Сохранить и продолжить
                  </button>
                </div>
              </div>
            </fieldset>

            <p class="wizard-status workflow-status" data-wizard-status role="status">
              Сначала сохраните контакт, затем ответы будут сохраняться автоматически по шагам.
            </p>
          </div>
        </div>
      </section>

      <div class="drawer-backdrop" data-drawer-backdrop hidden></div>

      <aside
        class="project-summary-drawer"
        id="project-summary-drawer"
        aria-label="Краткая информация по заявке"
        aria-hidden="true"
        data-project-summary-drawer
        hidden
      >
        <div class="drawer-head">
          <div>
            <div class="section-kicker">Заявка</div>
            <h2>Опросник по расчету</h2>
          </div>
          <button class="drawer-close" type="button" aria-label="Закрыть" data-drawer-close>×</button>
        </div>
        <div class="drawer-body">
          <dl class="drawer-metrics">
            <div>
              <dt>Площадь</dt>
              <dd><span data-summary-area>{defaultAreaSqm}</span> м²</dd>
            </div>
            <div>
              <dt>Тип объекта</dt>
              <dd data-summary-type>Частный дом</dd>
            </div>
            <div>
              <dt>Ориентировочная стоимость</dt>
              <dd data-total-byn>
                {formatRubles(initialCalculation.totals.totalBynRoundedRubles)}
                <img class="currency-symbol" src="/landing-v4/byn-symbol.svg" alt="" aria-hidden="true" />
                <span class="sr-only"> BYN</span>
              </dd>
            </div>
          </dl>
          <div class="summary-list" data-summary-list>
            {
              initialCalculation.lineItems.map((lineItem) => (
                <div class="summary-row">
                  <span>{lineItem.serviceSnapshot.title}</span>
                  <strong>
                    {formatRubles(initialSummaryRubles.get(lineItem.serviceId) ?? 0)}
                    <img
                      class="currency-symbol"
                      src="/landing-v4/byn-symbol.svg"
                      alt=""
                      aria-hidden="true"
                    />
                    <span class="sr-only"> BYN</span>
                  </strong>
                </div>
              ))
            }
          </div>
          <p class="drawer-copy">
            Площадь, тип объекта и выбранные услуги уже подставлены автоматически.
            Ответы попадут в техническое задание именно этого проекта.
          </p>
          <a class="drawer-link" href="/#calculator">Изменить расчет</a>
        </div>
      </aside>

      <aside
        class="section-drawer"
        id="section-drawer"
        aria-label="Разделы опросника"
        aria-hidden="true"
        data-section-drawer
        hidden
      >
        <div class="drawer-head">
          <div>
            <div class="section-kicker">Разделы</div>
            <h2>Структура ТЗ</h2>
          </div>
          <button class="drawer-close" type="button" aria-label="Закрыть" data-drawer-close>×</button>
        </div>
        <div class="drawer-body">
          <div class="section-nav" data-mobile-section-nav></div>
        </div>
      </aside>
    </main>
  </body>
</html>

<script>
  import {
    calculateEngineeringOffer,
    getQuestionnaireActiveOptions,
    getQuestionnaireActiveQuestions,
    getQuestionnaireActiveSections,
    getQuestionnaireQuestionAnswerType,
    publicCalculatorConfigResponseSchema,
    publicQuestionnaireDefinitionResponseSchema,
    publicQuestionnaireSessionResponseSchema,
    publicQuestionnaireStartResponseSchema,
    type CalculationResult,
    type EngineeringService,
    type QuestionnaireDefinition,
    type PublicQuestionnaireSession,
    type QuestionnaireAnswerInput,
    type QuestionnaireQuestion,
    type ServiceRecord,
  } from '@poznyak-engineering-calculator/contracts'
  import {
    maskPublicContactPhoneInput,
    validatePublicContactPhone,
  } from '../lib/public-contact-validation'

  type ProjectType = 'private' | 'apartment' | 'commercial'
  type CalculatorService = EngineeringService & { isPublic?: boolean }
  type QuestionnaireData = {
    version: string
    definition: QuestionnaireDefinition
    defaultAreaSqm: string
    areaLimits: {
      min: number
      max: number
      step: number
    }
    exchangeRate: {
      source: 'manual' | 'nbrb' | 'fallback'
      usdToBynRate: string
      asOf?: string
    }
    fallbackServices: CalculatorService[]
    selectedServiceIds: string[]
    selectedProjectType: ProjectType
  }
  type OfferChoiceState = {
    areaSqm?: string
    selectedServiceIds?: string[]
    projectType?: ProjectType
  }
  type QuestionnaireContactPrefill = {
    clientName?: string
    clientPhone?: string
    objectName?: string
    savedAt?: string
  }

  const dataElement = document.querySelector<HTMLScriptElement>('#questionnaire-data')
  const data = JSON.parse(dataElement?.textContent ?? '{}') as QuestionnaireData
  let activeDefinition: QuestionnaireDefinition = data.definition
  let allQuestions = questionnaireQuestions(activeDefinition)
  const configStatus = document.querySelector<HTMLElement>('[data-config-status]')
  const summaryAreas = document.querySelectorAll<HTMLElement>('[data-summary-area]')
  const summaryTypes = document.querySelectorAll<HTMLElement>('[data-summary-type]')
  const summaryList = document.querySelector<HTMLElement>('[data-summary-list]')
  const totalBynElements = document.querySelectorAll<HTMLElement>('[data-total-byn]')
  const progressPercent = document.querySelector<HTMLElement>('[data-progress-percent]')
  const progressBar = document.querySelector<HTMLProgressElement>('[data-progress-bar]')
  const progressText = document.querySelector<HTMLElement>('[data-progress-text]')
  const currentSectionLabel = document.querySelector<HTMLElement>('[data-current-section]')
  const sectionNav = document.querySelector<HTMLElement>('[data-section-nav]')
  const mobileSectionNav = document.querySelector<HTMLElement>('[data-mobile-section-nav]')
  const mobileSectionName = document.querySelector<HTMLElement>('[data-mobile-section-name]')
  const mobileSectionsOpen = document.querySelector<HTMLButtonElement>('[data-mobile-sections-open]')
  const projectSummaryOpenButtons = document.querySelectorAll<HTMLButtonElement>('[data-project-summary-open]')
  const drawerBackdrop = document.querySelector<HTMLElement>('[data-drawer-backdrop]')
  const projectSummaryDrawer = document.querySelector<HTMLElement>('[data-project-summary-drawer]')
  const sectionDrawer = document.querySelector<HTMLElement>('[data-section-drawer]')
  const drawerCloseButtons = document.querySelectorAll<HTMLButtonElement>('[data-drawer-close]')
  const contactForm = document.querySelector<HTMLFormElement>('[data-contact-form]')
  const clientNameInput = document.querySelector<HTMLInputElement>('[data-client-name]')
  const clientPhoneInput = document.querySelector<HTMLInputElement>('[data-client-phone]')
  const phoneError = document.querySelector<HTMLElement>('[data-phone-error]')
  const objectNameInput = document.querySelector<HTMLTextAreaElement>('[data-object-name]')
  const consentInput = document.querySelector<HTMLInputElement>('[data-consent]')
  const startTrigger = document.querySelector<HTMLButtonElement>('[data-start-trigger]')
  const storedResumePanel = document.querySelector<HTMLElement>('[data-stored-resume-panel]')
  const storedResumeContinue = document.querySelector<HTMLButtonElement>('[data-stored-resume-continue]')
  const storedResumeClear = document.querySelector<HTMLButtonElement>('[data-stored-resume-clear]')
  const resumePanel = document.querySelector<HTMLElement>('[data-resume-panel]')
  const questionCard = document.querySelector<HTMLFieldSetElement>('[data-question-card]')
  const questionTitle = document.querySelector<HTMLElement>('[data-question-title]')
  const questionMeta = document.querySelector<HTMLElement>('[data-question-meta]')
  const questionState = document.querySelector<HTMLElement>('[data-question-state]')
  const skippedNote = document.querySelector<HTMLElement>('[data-skipped-note]')
  const optionList = document.querySelector<HTMLElement>('[data-option-list]')
  const customAnswer = document.querySelector<HTMLTextAreaElement>('[data-custom-answer]')
  const customAnswerLabelText = document.querySelector<HTMLElement>('[data-custom-answer-label]')
  const answerSkipped = document.querySelector<HTMLButtonElement>('[data-answer-skipped]')
  const prevQuestion = document.querySelector<HTMLButtonElement>('[data-prev-question]')
  const nextQuestion = document.querySelector<HTMLButtonElement>('[data-next-question]')
  const wizardStatuses = document.querySelectorAll<HTMLElement>('[data-wizard-status]')

  const numberFormatter = new Intl.NumberFormat('ru-RU')
  const supportedPricingTypes = new Set(['fixed', 'per_sqm'])
  const projectTypeLabels: Record<ProjectType, string> = {
    private: 'Частный дом',
    apartment: 'Квартира',
    commercial: 'Коммерческий объект',
  }
  const apiBaseUrl = (import.meta.env.PUBLIC_API_URL ?? '').trim().replace(/\/$/, '')
  const offerStateStorageKey = 'pzk-offer-choice-state-v1'
  const questionnaireSessionStorageKey = 'pzk-questionnaire-resume-v2'
  const questionnaireContactPrefillStorageKey = 'pzk-questionnaire-contact-prefill-v1'

  const initialChoiceState = readOfferChoiceState()
  const hasExplicitServiceSelection = Array.isArray(initialChoiceState.selectedServiceIds)
  let services = normalizeServices(data.fallbackServices)
  let selectedProjectType: ProjectType = initialChoiceState.projectType ?? data.selectedProjectType ?? 'private'
  let selectedServiceIds = new Set(
    hasExplicitServiceSelection
      ? initialChoiceState.selectedServiceIds
      : data.selectedServiceIds,
  )
  let areaSqm = parseArea(initialChoiceState.areaSqm ?? data.defaultAreaSqm).canonical
  let currentCalculation: CalculationResult | null = null
  let hasApiConfig = false
  let isStarting = false
  let isSaving = false
  let startIdempotencyKey = createIdempotencyKey()
  let session: PublicQuestionnaireSession | null = null
  let currentQuestionIndex = 0
  let pendingStoredResume = readStoredQuestionnaireResume()
  const draftOptionByQuestionId = new Map<string, string>()

  attachHandlers()
  applyQuestionnaireContactPrefill()
  renderStaticShell()
  void bootstrap()

  async function bootstrap() {
    const resumeToken = resumeTokenFromUrl()

    if (resumeToken) {
      await resumeQuestionnaire(resumeToken)
    } else if (pendingStoredResume && !hasOfferChoiceQuery()) {
      setWizardStatus('На этом устройстве найден начатый опросник.', 'ready')
    }

    await loadPublicQuestionnaireDefinition()
    await loadPublicConfig()
    render()
  }

  function attachHandlers() {
    contactForm?.addEventListener('submit', (event) => {
      event.preventDefault()
      void startQuestionnaire()
    })

    clientNameInput?.addEventListener('input', resetStartKey)
    clientPhoneInput?.addEventListener('input', () => {
      maskPublicContactPhoneInput(clientPhoneInput)
      resetStartKey()
    })
    objectNameInput?.addEventListener('input', resetStartKey)
    consentInput?.addEventListener('change', resetStartKey)

    answerSkipped?.addEventListener('click', () => {
      void saveAnswer({
        questionId: currentQuestion().id,
        kind: 'skipped',
      }, { advance: true })
    })

    prevQuestion?.addEventListener('click', () => {
      currentQuestionIndex = Math.max(0, currentQuestionIndex - 1)
      render()
    })

    nextQuestion?.addEventListener('click', () => {
      void saveCurrentQuestionAndAdvance()
    })

    customAnswer?.addEventListener('input', () => {
      const question = currentQuestion()
      if (customAnswer.value.trim()) draftOptionByQuestionId.delete(question.id)
      updateQuestionControls()
    })

    storedResumeContinue?.addEventListener('click', () => {
      if (!pendingStoredResume) return
      void resumeQuestionnaire(pendingStoredResume.token)
    })

    storedResumeClear?.addEventListener('click', () => {
      clearStoredQuestionnaireResume()
      pendingStoredResume = null
      setWizardStatus('Можно начать новый опросник.', 'ready')
      render()
    })

    projectSummaryOpenButtons.forEach((button) => {
      button.addEventListener('click', () => openDrawer(projectSummaryDrawer))
    })

    mobileSectionsOpen?.addEventListener('click', () => openDrawer(sectionDrawer))
    drawerCloseButtons.forEach((button) => button.addEventListener('click', closeDrawers))
    drawerBackdrop?.addEventListener('click', closeDrawers)
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeDrawers()
    })
  }

  async function loadPublicConfig() {
    if (!apiBaseUrl) {
      hasApiConfig = false
      setConfigStatus(
        session ? '' : 'Опросник временно недоступен: не удалось загрузить настройки.',
        session ? undefined : 'error',
      )
      return
    }

    try {
      const response = await fetch(`${apiBaseUrl}/api/public/calculator-config`, {
        headers: { Accept: 'application/json' },
      })

      if (!response.ok) throw new Error(`Calculator config request failed: ${response.status}`)

      const payload = publicCalculatorConfigResponseSchema.parse(await response.json())
      const publicServices = normalizeServices(payload.services)
      data.exchangeRate = payload.exchangeRate

      if (publicServices.length === 0) {
        services = []
        selectedServiceIds = new Set()
        hasApiConfig = false
        setConfigStatus(
          session ? '' : 'Нет опубликованных услуг. Опросник можно будет начать позже.',
          session ? undefined : 'error',
        )
      } else {
        services = publicServices
        resolveSelectedServices()
        hasApiConfig = true
        setConfigStatus('')
      }
    } catch {
      hasApiConfig = false
      setConfigStatus(
        session ? '' : 'Опросник временно недоступен. Попробуйте начать позже.',
        session ? undefined : 'error',
      )
    }
  }

  async function startQuestionnaire() {
    if (isStarting) return

    const validation = validateContact()
    if (!validation.valid) {
      setWizardStatus('Проверьте имя, телефон и согласие.', 'error')
      return
    }

    if (!apiBaseUrl || !hasApiConfig || !currentCalculation || currentCalculation.lineItems.length === 0) {
      setWizardStatus('Для старта выберите разделы проекта и дождитесь загрузки настроек.', 'error')
      return
    }

    // TODO(PZK): route private/apartment/commercial to separate questionnaire definitions.
    const matchingResume = matchingStoredQuestionnaireResume(validation.clientName, validation.clientPhone)
    if (matchingResume) {
      setWizardStatus('Нашли сохраненный опросник на этом устройстве. Открываю продолжение...', 'loading')
      await resumeQuestionnaire(matchingResume.token)
      return
    }

    isStarting = true
    updateStartState()
    setWizardStatus('Сохраняю заявку и открываю опросник...', 'loading')

    try {
      const response = await fetch(`${apiBaseUrl}/api/public/questionnaires`, {
        method: 'POST',
        headers: {
          Accept: 'application/json',
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          idempotencyKey: startIdempotencyKey,
          clientName: validation.clientName,
          clientPhone: validation.clientPhone,
          objectName: questionnaireObjectName(),
          calculation: {
            areaSqm: currentCalculation.areaSqm,
            selectedServiceIds: currentCalculation.selectedServiceIds,
          },
          consentAccepted: true,
          source: 'public_questionnaire',
          referrer: document.referrer || undefined,
          utm: readAttributionMetadata(),
        }),
      })
      const payload = await response.json().catch(() => null)

      if (!response.ok) throw new Error(publicQuestionnaireErrorMessage(response.status, payload))

      const parsed = publicQuestionnaireStartResponseSchema.parse(payload)
      applyQuestionnaireSession(parsed.questionnaire, 'first-unanswered')
      storeQuestionnaireResume(parsed.questionnaire.publicToken, validation.clientName, validation.clientPhone)
      pendingStoredResume = readStoredQuestionnaireResume()
      setWizardStatus(
        response.status === 200
          ? 'Опросник уже был создан ранее. Продолжаем заполнение.'
          : 'Контакт сохранен. Теперь ответы будут сохраняться по шагам.',
        'ready',
      )
    } catch (error) {
      setWizardStatus(
        error instanceof Error ? error.message : 'Не удалось начать опросник. Попробуйте еще раз.',
        'error',
      )
    } finally {
      isStarting = false
      updateStartState()
      render()
    }
  }

  async function resumeQuestionnaire(token: string) {
    if (!apiBaseUrl) return

    try {
      const response = await fetch(`${apiBaseUrl}/api/public/questionnaires/${encodeURIComponent(token)}`, {
        headers: { Accept: 'application/json' },
      })
      if (!response.ok) {
        clearStoredQuestionnaireResume()
        pendingStoredResume = null
        setWizardStatus('Сохраненный опросник не найден. Можно начать новый.', 'error')
        render()
        return
      }
      const parsed = publicQuestionnaireSessionResponseSchema.parse(await response.json())
      applyQuestionnaireSession(parsed.questionnaire, 'first-unanswered')
      storeQuestionnaireResume(parsed.questionnaire.publicToken)
      pendingStoredResume = readStoredQuestionnaireResume()
      setWizardStatus('Открыт сохраненный опросник.', 'ready')
      render()
    } catch {
      setWizardStatus('Не удалось восстановить сохраненный опросник.', 'error')
      clearStoredQuestionnaireResume()
      pendingStoredResume = null
    }
  }

  async function saveAnswer(answer: QuestionnaireAnswerInput, options: { advance?: boolean } = {}) {
    if (!session || isSaving) return

    isSaving = true
    setWizardStatus('Сохраняю ответ...', 'loading')
    updateQuestionControls()

    try {
      const response = await fetch(
        `${apiBaseUrl}/api/public/questionnaires/${encodeURIComponent(session.publicToken)}/answers`,
        {
          method: 'PATCH',
          headers: {
            Accept: 'application/json',
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            answers: [answer],
          }),
        },
      )
      const payload = await response.json().catch(() => null)

      if (!response.ok) throw new Error(publicQuestionnaireErrorMessage(response.status, payload))

      const parsed = publicQuestionnaireSessionResponseSchema.parse(payload)
      applyQuestionnaireSession(parsed.questionnaire, 'preserve')
      draftOptionByQuestionId.delete(answer.questionId)
      if (options.advance) moveAfterQuestion(answer.questionId)
      setWizardStatus('Ответ сохранен.', 'ready')
    } catch (error) {
      setWizardStatus(
        error instanceof Error ? error.message : 'Не удалось сохранить ответ. Попробуйте еще раз.',
        'error',
      )
    } finally {
      isSaving = false
      render()
    }
  }

  function applyQuestionnaireSession(
    nextSession: PublicQuestionnaireSession,
    mode: 'first-unanswered' | 'preserve' = 'preserve',
  ) {
    session = nextSession
    applyQuestionnaireDefinition(nextSession.definition)
    if (mode === 'preserve') {
      clampCurrentQuestionIndex()
      return
    }
    const nextIndex = firstUnansweredQuestionIndex()
    currentQuestionIndex = nextIndex === -1 ? currentQuestionIndex : nextIndex
    clampCurrentQuestionIndex()
  }

  function applyQuestionnaireDefinition(definition: QuestionnaireDefinition) {
    activeDefinition = definition
    allQuestions = questionnaireQuestions(definition)
  }

  function renderStaticShell() {
    render()
  }

  function openDrawer(drawer: HTMLElement | null) {
    if (!drawer || !drawerBackdrop) return
    drawer.hidden = false
    drawer.setAttribute('aria-hidden', 'false')
    drawer.classList.add('is-open')
    drawerBackdrop.hidden = false
    drawerBackdrop.classList.add('is-open')
    if (drawer === projectSummaryDrawer) {
      projectSummaryOpenButtons.forEach((button) => button.setAttribute('aria-expanded', 'true'))
    }
    if (drawer === sectionDrawer) {
      mobileSectionsOpen?.setAttribute('aria-expanded', 'true')
    }
  }

  function closeDrawers() {
    for (const drawer of [projectSummaryDrawer, sectionDrawer]) {
      if (!drawer) continue
      drawer.classList.remove('is-open')
      drawer.setAttribute('aria-hidden', 'true')
      drawer.hidden = true
    }
    drawerBackdrop?.classList.remove('is-open')
    if (drawerBackdrop) drawerBackdrop.hidden = true
    projectSummaryOpenButtons.forEach((button) => button.setAttribute('aria-expanded', 'false'))
    mobileSectionsOpen?.setAttribute('aria-expanded', 'false')
  }

  function render() {
    renderCalculationSummary()
    renderSectionNav()
    renderProgress()
    renderQuestion()
    renderSessionPanels()
    updateStartState()
    updateQuestionControls()
  }

  function renderCalculationSummary() {
    const activeSession = session

    if (activeSession) {
      summaryAreas.forEach((element) => {
        element.textContent = compactArea(activeSession.calculation.areaSqm)
      })
      summaryTypes.forEach((element) => {
        element.textContent = projectTypeLabels[selectedProjectType]
      })
      if (summaryList) {
        summaryList.innerHTML = activeSession.calculation.serviceTitles
          .map(
            (title) => `
              <div class="summary-row">
                <span>${escapeHtml(title)}</span>
                <strong>Сохранено</strong>
              </div>
            `,
          )
          .join('')
      }
      totalBynElements.forEach((element) => {
        element.innerHTML = `${formatRubles(activeSession.calculation.totalBynRoundedRubles)} ${currencyMarkup()}`
      })
      return
    }

    const parsedArea = parseArea(areaSqm)
    areaSqm = parsedArea.canonical
    const canCalculate = parsedArea.valid && services.length > 0

    if (!canCalculate) {
      currentCalculation = null
      if (summaryList) {
        summaryList.innerHTML = `<div class="summary-row muted"><span>Разделы не выбраны</span><strong>0 ${currencyMarkup()}</strong></div>`
      }
      totalBynElements.forEach((element) => {
        element.innerHTML = `0 ${currencyMarkup()}`
      })
      return
    }

    resolveSelectedServices()
    const nextCalculation = calculateEngineeringOffer({
      areaSqm,
      selectedServiceIds: [...selectedServiceIds],
      services,
      exchangeRate: data.exchangeRate,
    })
    currentCalculation = nextCalculation

    summaryAreas.forEach((element) => {
      element.textContent = compactArea(nextCalculation.areaSqm)
    })
    summaryTypes.forEach((element) => {
      element.textContent = projectTypeLabels[selectedProjectType]
    })
    if (!summaryList || totalBynElements.length === 0) return

    const displayRubles = allocateDisplayBynRubles(nextCalculation)
    summaryList.innerHTML = nextCalculation.lineItems
      .map(
        (lineItem) => `
          <div class="summary-row">
            <span>${escapeHtml(lineItem.serviceSnapshot.title)}</span>
            <strong>${formatRubles(displayRubles.get(lineItem.serviceId) ?? 0)} ${currencyMarkup()}</strong>
          </div>
        `,
      )
      .join('')
    totalBynElements.forEach((element) => {
      element.innerHTML = `${formatRubles(nextCalculation.totals.totalBynRoundedRubles)} ${currencyMarkup()}`
    })
  }

  function renderProgress() {
    const activeQuestionList = activeQuestions()
    const progress = session?.progress ?? {
      completionPercent: 0,
      answeredCount: 0,
      totalQuestions: activeQuestionList.length,
      unknownCount: 0,
      skippedCount: 0,
    }

    if (progressPercent) progressPercent.textContent = `${progress.completionPercent}%`
    if (progressBar) {
      progressBar.value = progress.completionPercent
      progressBar.textContent = `${progress.completionPercent}%`
      progressBar.setAttribute('aria-valuenow', String(progress.completionPercent))
    }
    if (progressText) {
      const skippedCount = progress.unknownCount + progress.skippedCount
      progressText.textContent = skippedCount > 0
        ? `Заполнено ${progress.answeredCount} из ${progress.totalQuestions} вопросов · пропущено ${skippedCount}`
        : `Заполнено ${progress.answeredCount} из ${progress.totalQuestions} вопросов`
    }
    if (currentSectionLabel) currentSectionLabel.textContent = `Текущий раздел: ${currentSection().title.toLowerCase()}`
    if (mobileSectionName) mobileSectionName.textContent = currentSection().title
  }

  function renderSectionNav() {
    const containers = [sectionNav, mobileSectionNav].filter((container): container is HTMLElement => Boolean(container))
    if (containers.length === 0) return
    const sections = activeSections()
    const answers = answersByQuestionId()

    containers.forEach((container) => {
      container.innerHTML = sections
        .map((section, index) => {
          const answeredInSection = section.questions.filter((question) => answers.has(question.id)).length
          const skippedInSection = section.questions.filter((question) => answers.get(question.id)?.kind === 'skipped').length
          const percent = section.questions.length > 0
            ? Math.round((answeredInSection / section.questions.length) * 100)
            : 0
          const isCurrent = section.questions.some((question) => question.id === currentQuestion().id)
          const state = answeredInSection === section.questions.length
            ? 'complete'
            : skippedInSection > 0
              ? 'skipped'
              : 'pending'

          return `
            <button
              class="section-nav-item${isCurrent ? ' is-active' : ''}"
              type="button"
              data-section-id="${escapeHtml(section.id)}"
              data-state="${state}"
            >
              <span class="section-index">${String(index + 1).padStart(2, '0')}</span>
              <span class="section-copy">
                <strong>${escapeHtml(section.title)}</strong>
                <span class="section-progress-mini" aria-hidden="true"><i style="width:${percent}%"></i></span>
              </span>
              <span class="section-count">${answeredInSection}/${section.questions.length}</span>
            </button>
          `
        })
        .join('')

      container.querySelectorAll<HTMLButtonElement>('button[data-section-id]').forEach((button) => {
        button.addEventListener('click', () => {
          const section = activeSections().find((item) => item.id === button.dataset.sectionId)
          if (!section) return
          const firstQuestion = section.questions[0]
          currentQuestionIndex = Math.max(0, activeQuestions().findIndex((question) => question.id === firstQuestion.id))
          closeDrawers()
          render()
        })
      })
    })
  }

  function renderQuestion() {
    if (!questionCard || !session) {
      if (questionCard) questionCard.hidden = true
      return
    }

    const question = currentQuestion()
    const section = currentSection()
    const answer = answersByQuestionId().get(question.id)
    const draftOptionId = draftOptionByQuestionId.get(question.id)
    const answerType = getQuestionnaireQuestionAnswerType(question)
    const options = visibleQuestionOptions(question)
    questionCard.hidden = false
    if (questionTitle) questionTitle.textContent = question.prompt
    if (questionMeta) {
      questionMeta.textContent = `${section.title} · вопрос ${currentQuestionIndex + 1} из ${activeQuestions().length}`
    }
    if (questionState) {
      const state = answer?.kind === 'skipped'
        ? 'Пропущен'
        : answer
          ? 'Ответ есть'
          : 'Не отвечен'
      questionState.textContent = state
      questionState.dataset.state = answer?.kind === 'skipped' ? 'skipped' : answer ? 'answered' : 'empty'
    }
    if (skippedNote) skippedNote.hidden = answer?.kind !== 'skipped'
    if (customAnswer) {
      customAnswer.value = answer?.kind === 'custom' ? answer.customText ?? '' : ''
      customAnswer.inputMode = answerType === 'number' ? 'decimal' : 'text'
      customAnswer.maxLength = answerType === 'number' ? 40 : 2000
      customAnswer.placeholder = answerType === 'number'
        ? 'Например: 180 или 180,5'
        : 'Например: какие работы уже выполнены, какие решения еще можно изменить'
      customAnswer.removeAttribute('aria-invalid')
    }
    if (customAnswerLabelText) {
      customAnswerLabelText.textContent = answerType === 'number'
        ? 'Введите число'
        : options.length > 0
          ? 'Если нужно, уточните'
          : 'Ваш ответ'
    }

    if (optionList) {
      optionList.innerHTML = options.length
        ? options
          .map(
            (option, index) => `
              <button
                class="answer-option${(draftOptionId ?? answer?.optionId) === option.id ? ' is-selected' : ''}"
                type="button"
                data-option-id="${escapeHtml(option.id)}"
                aria-pressed="${(draftOptionId ?? answer?.optionId) === option.id ? 'true' : 'false'}"
              >
                <span class="answer-radio" aria-hidden="true"></span>
                <span class="answer-index" aria-hidden="true">${String(index + 1).padStart(2, '0')}</span>
                <span class="answer-copy">
                  <strong>${escapeHtml(option.label)}</strong>
                  ${option.hint ? `<small>${escapeHtml(option.hint)}</small>` : ''}
                </span>
              </button>
            `,
          )
          .join('')
        : answerType === 'number'
          ? '<p class="empty-options">Для этого вопроса нужно числовое значение.</p>'
          : '<p class="empty-options">Для этого вопроса нужен короткий текстовый ответ.</p>'

      optionList.querySelectorAll<HTMLButtonElement>('button[data-option-id]').forEach((button) => {
        button.addEventListener('click', () => {
          draftOptionByQuestionId.set(question.id, button.dataset.optionId ?? '')
          if (customAnswer) customAnswer.value = ''
          renderQuestion()
        })
      })
    }
  }

  function renderSessionPanels() {
    const hasSession = Boolean(session)
    if (contactForm) contactForm.hidden = hasSession
    if (storedResumePanel) storedResumePanel.hidden = hasSession || !pendingStoredResume || hasOfferChoiceQuery()
    if (resumePanel) resumePanel.hidden = !hasSession
  }

  function updateStartState() {
    if (!startTrigger) return
    const disabled =
      isStarting ||
      Boolean(session) ||
      !apiBaseUrl ||
      !hasApiConfig ||
      !currentCalculation ||
      currentCalculation.lineItems.length === 0
    startTrigger.disabled = disabled
    startTrigger.textContent = isStarting ? 'Сохраняю...' : 'Начать подробный опросник'
  }

  function updateQuestionControls() {
    const disabled = isSaving || !session
    for (const button of [answerSkipped, prevQuestion, nextQuestion]) {
      if (button) button.disabled = disabled
    }
    if (prevQuestion) prevQuestion.disabled = disabled || currentQuestionIndex === 0
    if (nextQuestion) nextQuestion.disabled = disabled || activeQuestions().length === 0
  }

  function validateContact() {
    const clientName = clientNameInput?.value.trim() ?? ''
    const clientPhone = clientPhoneInput?.value.trim() ?? ''
    const phone = validatePublicContactPhone(clientPhone)
    const nameValid = clientName.length >= 2 && clientName.length <= 120
    const phoneValid = phone.valid
    const consentValid = consentInput?.checked === true

    setInputValidity(clientNameInput, nameValid)
    setInputValidity(clientPhoneInput, phoneValid)
    setInputValidity(consentInput, consentValid)
    if (phoneError) phoneError.hidden = phoneValid

    return {
      valid: nameValid && phoneValid && consentValid,
      clientName,
      clientPhone: phone.normalized ?? clientPhone,
    }
  }

  function setInputValidity(input: HTMLInputElement | null, isValid: boolean) {
    if (!input) return
    if (isValid) {
      input.removeAttribute('aria-invalid')
    } else {
      input.setAttribute('aria-invalid', 'true')
    }
  }

  async function saveCurrentQuestionAndAdvance() {
    if (!session) return

    const question = currentQuestion()
    const draftOptionId = draftOptionByQuestionId.get(question.id)
    const text = customAnswer?.value.trim() ?? ''
    const existingAnswer = answersByQuestionId().get(question.id)
    const answerType = getQuestionnaireQuestionAnswerType(question)

    if (draftOptionId) {
      await saveAnswer({
        questionId: question.id,
        kind: 'option',
        optionId: draftOptionId,
      }, { advance: true })
      return
    }

    if (text) {
      const customText = answerType === 'number' ? parseQuestionnaireNumber(text) : text
      if (!customText) {
        setWizardStatus('Введите число, например 180 или 180,5.', 'error')
        customAnswer?.setAttribute('aria-invalid', 'true')
        return
      }

      customAnswer?.removeAttribute('aria-invalid')
      await saveAnswer({
        questionId: question.id,
        kind: 'custom',
        customText,
      }, { advance: true })
      return
    }

    if (existingAnswer) {
      moveAfterQuestion(question.id)
      render()
      return
    }

    setWizardStatus(
      answerType === 'number'
        ? 'Введите число или нажмите «Пропустить».'
        : 'Выберите вариант, введите свой ответ или нажмите «Пропустить».',
      'error',
    )
    customAnswer?.setAttribute('aria-invalid', 'true')
  }

  function moveAfterQuestion(questionId: string) {
    const questions = activeQuestions()
    const index = questions.findIndex((question) => question.id === questionId)
    if (index === -1) {
      currentQuestionIndex = Math.min(currentQuestionIndex, Math.max(0, questions.length - 1))
      return
    }
    currentQuestionIndex = Math.min(index + 1, Math.max(0, questions.length - 1))
  }

  function clampCurrentQuestionIndex() {
    currentQuestionIndex = Math.min(currentQuestionIndex, Math.max(0, activeQuestions().length - 1))
  }

  function currentQuestion() {
    return activeQuestions()[currentQuestionIndex] ?? activeQuestions()[0] ?? allQuestions[0]
  }

  function currentSection() {
    return activeSections().find((section) =>
      section.questions.some((question) => question.id === currentQuestion().id),
    ) ?? activeSections()[0] ?? currentDefinition().sections[0]
  }

  function firstUnansweredQuestionIndex() {
    const answers = answersByQuestionId()
    const index = activeQuestions().findIndex((question) => !answers.has(question.id))
    return index
  }

  function activeQuestions() {
    return getQuestionnaireActiveQuestions(session?.answers ?? [], currentDefinition())
  }

  function activeSections() {
    return getQuestionnaireActiveSections(session?.answers ?? [], currentDefinition())
  }

  function visibleQuestionOptions(question: QuestionnaireQuestion) {
    return getQuestionnaireActiveOptions(question, session?.answers ?? [], currentDefinition()).filter(
      (option) => option.id !== 'UNKNOWN' && !/пока не/i.test(option.label),
    )
  }

  function currentDefinition() {
    return session?.definition ?? activeDefinition
  }

  function questionnaireQuestions(definition: QuestionnaireDefinition) {
    return definition.sections.flatMap((section) => section.questions)
  }

  function answersByQuestionId(options: { includeInactive?: boolean } = {}) {
    const answers = (session?.answers ?? []).filter((answer) => options.includeInactive || answer.isActive)
    return new Map(answers.map((answer) => [answer.questionId, answer]))
  }

  function readOfferChoiceState(): OfferChoiceState {
    const searchParams = new URLSearchParams(window.location.search)
    const servicesFromQuery = (searchParams.get('services') ?? '')
      .split(',')
      .map((serviceId) => serviceId.trim())
      .filter(Boolean)
    const typeFromQuery = searchParams.get('type')
    const hasServicesQuery = searchParams.has('services')
    const queryState: OfferChoiceState = {
      areaSqm: searchParams.get('area') ?? undefined,
      selectedServiceIds: hasServicesQuery ? servicesFromQuery : undefined,
      projectType: isProjectType(typeFromQuery) ? typeFromQuery : undefined,
    }

    if (queryState.areaSqm || queryState.selectedServiceIds || queryState.projectType) {
      return queryState
    }

    try {
      const rawState = sessionStorage.getItem(offerStateStorageKey)
      if (!rawState) return {}
      const parsed = JSON.parse(rawState) as OfferChoiceState
      return {
        areaSqm: typeof parsed.areaSqm === 'string' ? parsed.areaSqm : undefined,
        selectedServiceIds: Array.isArray(parsed.selectedServiceIds)
          ? parsed.selectedServiceIds.filter((serviceId) => typeof serviceId === 'string')
          : undefined,
        projectType: isProjectType(parsed.projectType)
          ? parsed.projectType
          : undefined,
      }
    } catch {
      return {}
    }
  }

  function normalizeServices(source: Array<CalculatorService | ServiceRecord>): CalculatorService[] {
    return source
      .filter((service) => service.isActive && supportedPricingTypes.has(service.pricingType))
      .map((service) => ({
        id: service.id,
        title: service.title,
        description: service.description ?? null,
        pricingType: service.pricingType,
        priceUsdCents: service.priceUsdCents,
        isActive: service.isActive,
        sortOrder: service.sortOrder,
        pricingRule: service.pricingRule ?? undefined,
        formulaVersion: service.formulaVersion ?? undefined,
        createdAt: service.createdAt,
        updatedAt: service.updatedAt,
        isPublic: 'isPublic' in service ? service.isPublic : true,
      }))
      .sort((first, second) => first.sortOrder - second.sortOrder)
  }

  function resolveSelectedServices() {
    const availableServiceIds = new Set(services.map((service) => service.id))
    const validSelectedServiceIds = [...selectedServiceIds].filter((serviceId) =>
      availableServiceIds.has(serviceId),
    )
    const shouldPreserveExplicitEmptySelection = hasExplicitServiceSelection && selectedServiceIds.size === 0
    selectedServiceIds = new Set(
      shouldPreserveExplicitEmptySelection
        ? []
        : validSelectedServiceIds.length > 0
          ? validSelectedServiceIds
          : defaultSelectedServiceIds(services),
    )
  }

  function defaultSelectedServiceIds(source: CalculatorService[]) {
    return source.slice(0, Math.min(3, source.length)).map((service) => service.id)
  }

  function parseArea(value: string) {
    const canonical = value.trim().replace(',', '.')

    if (!/^(?:0|[1-9]\d{0,7})(?:\.\d{1,2})?$/.test(canonical)) {
      return { valid: false, canonical: data.defaultAreaSqm }
    }

    const numericValue = Number(canonical)
    if (numericValue < data.areaLimits.min || numericValue > data.areaLimits.max) {
      return { valid: false, canonical: data.defaultAreaSqm }
    }

    return { valid: true, canonical }
  }

  function parseQuestionnaireNumber(value: string) {
    const canonical = value.trim().replace(',', '.')
    if (!/^-?(?:0|[1-9]\d{0,7})(?:\.\d{1,3})?$/.test(canonical)) return null
    return canonical
  }

  async function loadPublicQuestionnaireDefinition() {
    if (!apiBaseUrl) return

    try {
      const response = await fetch(`${apiBaseUrl}/api/public/questionnaire-definition`, {
        headers: { Accept: 'application/json' },
      })

      if (!response.ok) throw new Error(`Questionnaire definition request failed: ${response.status}`)

      const payload = publicQuestionnaireDefinitionResponseSchema.parse(await response.json())
      applyQuestionnaireDefinition(payload.questionnaireDefinition)
      if (payload.questionnaireDefinition.status === 'static_fallback') {
        setWizardStatus('Открыта резервная опубликованная версия опросника.', 'ready')
      }
    } catch {
      setWizardStatus('Открыта резервная версия опросника. После старта ответы сохранятся в актуальной backend-версии.', 'ready')
    }
  }

  function isProjectType(value: unknown): value is ProjectType {
    return value === 'private' || value === 'apartment' || value === 'commercial'
  }

  function questionnaireObjectName() {
    const comment = objectNameInput?.value.trim() ?? ''
    const base = `Подробный опросник. Тип проекта: ${projectTypeLabels[selectedProjectType]}`
    return comment ? `${base}. ${comment}`.slice(0, 160) : base
  }

  function readAttributionMetadata() {
    const searchParams = new URLSearchParams(window.location.search)
    const metadata: Record<string, string> = {}

    searchParams.forEach((value, key) => {
      if (!/^(utm_[a-z0-9_]+|gclid|yclid|fbclid)$/i.test(key)) return
      const trimmedValue = value.trim()
      if (!trimmedValue) return
      metadata[key.slice(0, 64)] = trimmedValue.slice(0, 500)
    })

    return Object.keys(metadata).length > 0 ? metadata : undefined
  }

  function resumeTokenFromUrl() {
    return new URLSearchParams(window.location.search).get('token')?.trim() || null
  }

  function applyQuestionnaireContactPrefill() {
    if (resumeTokenFromUrl()) return

    try {
      const parsed = JSON.parse(
        sessionStorage.getItem(questionnaireContactPrefillStorageKey) ?? '{}',
      ) as QuestionnaireContactPrefill
      const savedAt = parsed.savedAt ? new Date(parsed.savedAt).getTime() : 0
      if (!Number.isFinite(savedAt) || Date.now() - savedAt > 24 * 60 * 60 * 1_000) return

      if (clientNameInput && !clientNameInput.value.trim() && typeof parsed.clientName === 'string') {
        clientNameInput.value = parsed.clientName.slice(0, 120)
      }
      if (clientPhoneInput && !clientPhoneInput.value.trim() && typeof parsed.clientPhone === 'string') {
        clientPhoneInput.value = parsed.clientPhone.slice(0, 40)
      }
      if (objectNameInput && !objectNameInput.value.trim() && typeof parsed.objectName === 'string') {
        objectNameInput.value = parsed.objectName.slice(0, 160)
      }
    } catch {
      // Prefill is only a convenience after the quick КП flow.
    }
  }

  function storeQuestionnaireResume(token: string, clientName?: string, clientPhone?: string) {
    try {
      const existing = readStoredQuestionnaireResume()
      const phone = clientPhone ? validatePublicContactPhone(clientPhone).normalized : existing?.clientPhone
      const name = clientName?.trim().toLowerCase() || existing?.clientName
      localStorage.setItem(questionnaireSessionStorageKey, JSON.stringify({
        token,
        clientName: name,
        clientPhone: phone,
        updatedAt: new Date().toISOString(),
      }))
    } catch {
      // Explicit resume links still work even if local storage is unavailable.
    }
  }

  function readStoredQuestionnaireResume() {
    try {
      const parsed = JSON.parse(localStorage.getItem(questionnaireSessionStorageKey) ?? '{}') as {
        token?: unknown
        clientName?: unknown
        clientPhone?: unknown
      }
      if (typeof parsed.token !== 'string' || !/^[A-Za-z0-9_-]{32,128}$/.test(parsed.token)) {
        return null
      }
      return {
        token: parsed.token,
        clientName: typeof parsed.clientName === 'string' ? parsed.clientName : undefined,
        clientPhone: typeof parsed.clientPhone === 'string' ? parsed.clientPhone : undefined,
      }
    } catch {
      return null
    }
  }

  function matchingStoredQuestionnaireResume(clientName: string, clientPhone: string) {
    const stored = readStoredQuestionnaireResume()
    if (!stored) return null

    const phone = validatePublicContactPhone(clientPhone).normalized
    const name = clientName.trim().toLowerCase()
    if (!stored.clientPhone || !stored.clientName || !phone) return null
    return stored.clientPhone === phone && stored.clientName === name ? stored : null
  }

  function clearStoredQuestionnaireResume() {
    try {
      localStorage.removeItem(questionnaireSessionStorageKey)
    } catch {
      // Nothing to clear.
    }
  }

  function hasOfferChoiceQuery() {
    const searchParams = new URLSearchParams(window.location.search)
    return searchParams.has('area') || searchParams.has('services') || searchParams.has('type')
  }

  function resetStartKey() {
    startIdempotencyKey = createIdempotencyKey()
  }

  function createIdempotencyKey() {
    if ('randomUUID' in crypto) {
      return crypto.randomUUID()
    }

    return `${Date.now().toString(36)}${Math.random().toString(36).slice(2, 18)}`
  }

  function setConfigStatus(message: string, state?: 'error') {
    if (!configStatus) return
    const shouldShow = Boolean(message.trim()) && state === 'error'
    configStatus.hidden = !shouldShow
    configStatus.textContent = shouldShow ? message : ''
    configStatus.classList.toggle('is-error', state === 'error')
  }

  function setWizardStatus(message: string, state?: 'ready' | 'error' | 'loading') {
    wizardStatuses.forEach((wizardStatus) => {
      wizardStatus.textContent = message
      wizardStatus.classList.toggle('is-ready', state === 'ready')
      wizardStatus.classList.toggle('is-error', state === 'error')
      wizardStatus.classList.toggle('is-loading', state === 'loading')
    })
  }

  function publicQuestionnaireErrorMessage(status: number, payload: unknown) {
    if (status === 400) return 'Проверьте поля формы.'
    if (status === 404) return 'Сохраненный опросник не найден.'
    if (status === 409 && isDuplicateQuestionnairePayload(payload)) {
      return 'Похоже, опросник уже создан. Используйте старую ссылку, Telegram-сообщение или обратитесь к менеджеру.'
    }
    if (status === 409) return 'Выбранные разделы изменились. Вернитесь к калькулятору и повторите старт.'
    if (status === 429) return 'Слишком много отправок подряд. Попробуйте немного позже.'
    return 'Не удалось выполнить действие. Попробуйте еще раз.'
  }

  function isDuplicateQuestionnairePayload(payload: unknown) {
    if (!payload || typeof payload !== 'object') return false
    const record = payload as Record<string, unknown>
    const error = record.error && typeof record.error === 'object'
      ? record.error as Record<string, unknown>
      : null
    const message = typeof error?.message === 'string' ? error.message : ''
    return /questionnaire lead already exists|опросник уже/i.test(message)
  }

  function allocateDisplayBynRubles(calculation: CalculationResult) {
    const floorRows = calculation.lineItems.map((lineItem, index) => ({
      serviceId: lineItem.serviceId,
      rubles: Math.floor(lineItem.totalBynCents / 100),
      remainder: lineItem.totalBynCents % 100,
      index,
    }))
    const floorTotal = floorRows.reduce((total, row) => total + row.rubles, 0)
    const remainingRubles = calculation.totals.totalBynRoundedRubles - floorTotal
    const rowsByRemainder = [...floorRows].sort(
      (first, second) => second.remainder - first.remainder || first.index - second.index,
    )

    for (const row of rowsByRemainder.slice(0, Math.max(0, remainingRubles))) {
      row.rubles += 1
    }

    return new Map(rowsByRemainder.map((row) => [row.serviceId, row.rubles]))
  }

  function formatRubles(value: number) {
    return numberFormatter.format(value)
  }

  function compactArea(value: string) {
    return value.replace(/\.0+$/, '').replace(/(\.\d*[1-9])0+$/, '$1')
  }

  function currencyMarkup() {
    return '<img class="currency-symbol" src="/landing-v4/byn-symbol.svg" alt="" aria-hidden="true"><span class="sr-only"> BYN</span>'
  }

  function escapeHtml(value: string) {
    return value
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;')
  }
</script>

