---
import ProjectExampleRequestForm from '../../components/ProjectExampleRequestForm.astro'
import { loadProjectCases, type ProjectCase } from '../../lib/project-cases'
import { absoluteUrl, createPageMeta, siteName } from '../../lib/seo'

export async function getStaticPaths() {
  const projectCases = await loadProjectCases()
  return projectCases.map((projectCase) => ({
    params: { slug: projectCase.slug },
    props: { projectCase },
  }))
}

type Props = {
  projectCase: ProjectCase
}

const { projectCase } = Astro.props
const pageMeta = createPageMeta({
  siteUrl: import.meta.env.PUBLIC_WEBSITE_URL,
  path: `/projects/${projectCase.slug}/`,
  title: projectCase.seoTitle,
  description: projectCase.seoDescription,
  imagePath: projectCase.coverImageUrl,
})
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebPage',
      '@id': `${pageMeta.canonicalUrl}#webpage`,
      url: pageMeta.canonicalUrl,
      name: pageMeta.title,
      description: pageMeta.description,
      isPartOf: {
        '@type': 'WebSite',
        name: siteName,
        url: pageMeta.siteUrl,
      },
    },
    {
      '@type': 'CreativeWork',
      '@id': `${pageMeta.canonicalUrl}#case`,
      name: projectCase.title,
      description: projectCase.description,
      image: projectCase.fragments.map((fragment) => absoluteUrl(pageMeta.siteUrl, fragment.imageUrl)),
      about: projectCase.engineeringSections,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Главная',
          item: `${pageMeta.siteUrl}/`,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Реализованные проекты',
          item: `${pageMeta.siteUrl}/projects/`,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: projectCase.title,
          item: pageMeta.canonicalUrl,
        },
      ],
    },
  ],
}
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Nunito:wght@700;800&display=swap"
      rel="stylesheet"
    />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageMeta.title}</title>
    <meta name="description" content={pageMeta.description} />
    <meta name="robots" content={pageMeta.robots} />
    <link rel="canonical" href={pageMeta.canonicalUrl} />
    <meta property="og:locale" content="ru_BY" />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageMeta.title} />
    <meta property="og:description" content={pageMeta.description} />
    <meta property="og:url" content={pageMeta.canonicalUrl} />
    <meta property="og:image" content={pageMeta.imageUrl} />
    <meta property="og:image:secure_url" content={pageMeta.imageUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:alt" content={projectCase.coverImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageMeta.title} />
    <meta name="twitter:description" content={pageMeta.description} />
    <meta name="twitter:image" content={pageMeta.imageUrl} />
    <meta name="twitter:image:alt" content={projectCase.coverImageAlt} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <header class="header">
      <a class="brand" href="/" aria-label="На главную ИП Позняк">
        <span>ПЗ</span>
        <strong>ИП Позняк</strong>
      </a>
      <nav aria-label="Публичная навигация">
        <a href="/#calculator">Калькулятор</a>
        <a href="/projects/">Проекты</a>
        <a href="/#contacts">Контакты</a>
      </nav>
    </header>

    <main>
      <article>
        <section class="case-hero">
          <div class="shell hero-grid">
            <div class="hero-copy">
              <a class="back-link" href="/projects/">Реализованные проекты</a>
              <p class="eyebrow">{projectCase.objectType} · {projectCase.areaSqm}</p>
              <h1>{projectCase.title}</h1>
              <p>{projectCase.description}</p>
              <div class="pill-row" aria-label="Разделы инженерии">
                {projectCase.engineeringSections.map((section) => <span>{section}</span>)}
              </div>
            </div>
            <figure class="hero-media">
              <img src={projectCase.coverImageUrl} alt={projectCase.coverImageAlt} />
              <figcaption>{projectCase.location}</figcaption>
            </figure>
          </div>
        </section>

        <section class="section" aria-labelledby="task-title">
          <div class="shell case-layout">
            <aside class="case-facts" aria-label="Параметры проекта">
              <div>
                <span>Тип объекта</span>
                <strong>{projectCase.objectType}</strong>
              </div>
              <div>
                <span>Площадь</span>
                <strong>{projectCase.areaSqm}</strong>
              </div>
              <div>
                <span>Разделы</span>
                <strong>{projectCase.engineeringSections.join(', ')}</strong>
              </div>
            </aside>
            <div class="case-text">
              <p class="eyebrow">Задача</p>
              <h2 id="task-title">Что нужно было решить</h2>
              <p>{projectCase.initialTask}</p>
              <p>{projectCase.solutionSummary}</p>
              <button
                class="primary-btn"
                type="button"
                data-example-select
                data-example-slug={projectCase.exampleSlugs[0] ?? 'ov'}
                aria-controls="case-request-form"
              >
                Получить полный пример
              </button>
            </div>
          </div>
        </section>

        <section class="section soft" aria-labelledby="fragments-title">
          <div class="shell">
            <div class="section-head">
              <p class="eyebrow">Фрагменты документации</p>
              <h2 id="fragments-title">Что показывает каждый лист</h2>
              <p>Это не полный PDF-комплект, а отдельные обезличенные фрагменты. Полный пример остается gated.</p>
            </div>
            <div class="fragment-list">
              {
                projectCase.fragments.map((fragment, index) => (
                  <figure class="fragment-card">
                    <img src={fragment.imageUrl} alt={fragment.imageAlt} loading={index === 0 ? 'eager' : 'lazy'} />
                    <figcaption>
                      <span>{String(index + 1).padStart(2, '0')}</span>
                      <strong>{fragment.title}</strong>
                      <p>{fragment.caption}</p>
                    </figcaption>
                  </figure>
                ))
              }
            </div>
          </div>
        </section>

        <section class="section" aria-labelledby="case-delivery-title">
          <div class="shell narrow">
            <div class="section-head">
              <p class="eyebrow">Получить пример</p>
              <h2 id="case-delivery-title">Полный PDF только после контакта</h2>
              <p>После отправки формы backend создаст заявку, а Telegram delivery предложит бот-ссылку при готовой настройке. Если Telegram недоступен, появятся защищенные token-ссылки.</p>
            </div>
            <ProjectExampleRequestForm
              id="case-request-form"
              title={`Получить пример: ${projectCase.title}`}
              description="Оставьте контакт, чтобы получить защищенную выдачу PDF-примера по этому кейсу."
              source={`project_case:${projectCase.slug}`}
              selectedSlugs={projectCase.exampleSlugs}
              submitLabel="Получить пример проекта"
            />
          </div>
        </section>
      </article>
    </main>
  </body>
</html>

<style>
  :root {
    --font-heading: "Nunito", "Inter", system-ui, sans-serif;
    --font-body: "Inter", system-ui, sans-serif;
    --ink: #102033;
    --body: #536273;
    --muted: #7f8f9f;
    --line: #dce4ec;
    --paper: #ffffff;
    --soft: #f4f7fa;
    --blue: #0b5fb5;
    --green: #17875d;
    --shadow: 0 18px 50px rgba(16, 32, 51, 0.08);
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--paper);
    color: var(--ink);
    font-family: var(--font-body);
  }

  a {
    color: inherit;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .header {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    border-bottom: 1px solid rgba(220, 228, 236, 0.88);
    background: rgba(255, 255, 255, 0.95);
    padding: 14px clamp(16px, 4vw, 44px);
    backdrop-filter: blur(14px);
  }

  .brand,
  nav,
  .pill-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
  }

  .brand {
    gap: 10px;
    text-decoration: none;
  }

  .brand span {
    display: grid;
    width: 34px;
    height: 34px;
    place-items: center;
    border-radius: 8px;
    background: var(--ink);
    color: #ffffff;
    font-family: var(--font-heading);
    font-size: 13px;
    font-weight: 800;
  }

  nav {
    gap: 18px;
    color: var(--body);
    font-size: 14px;
    font-weight: 700;
  }

  nav a,
  .back-link {
    text-decoration: none;
  }

  .shell {
    width: min(1160px, calc(100% - 32px));
    margin: 0 auto;
  }

  .shell.narrow {
    width: min(780px, calc(100% - 32px));
  }

  .case-hero {
    border-bottom: 1px solid var(--line);
    background: var(--soft);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(320px, 0.68fr);
    gap: clamp(24px, 5vw, 68px);
    align-items: end;
    min-height: min(620px, calc(100dvh - 64px));
    padding: 70px 0 54px;
  }

  .hero-copy {
    display: grid;
    gap: 16px;
  }

  .back-link,
  .eyebrow {
    color: var(--blue);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .eyebrow {
    margin: 0;
  }

  h1,
  h2,
  h3 {
    margin: 0;
    font-family: var(--font-heading);
    line-height: 1.08;
  }

  h1 {
    font-size: clamp(38px, 6vw, 68px);
  }

  h2 {
    font-size: clamp(28px, 4vw, 44px);
  }

  .hero-copy p,
  .section-head p,
  .case-text p,
  .fragment-card p {
    color: var(--body);
    font-size: 16px;
    line-height: 1.65;
  }

  .hero-media {
    margin: 0;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
    box-shadow: var(--shadow);
  }

  .hero-media img {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: 8px 8px 0 0;
    object-fit: cover;
  }

  .hero-media figcaption {
    padding: 12px 14px;
    color: var(--muted);
    font-size: 13px;
    font-weight: 800;
  }

  .pill-row {
    gap: 8px;
  }

  .pill-row span {
    border: 1px solid #cfe0ee;
    border-radius: 999px;
    background: #eff6fc;
    color: var(--blue);
    padding: 6px 10px;
    font-size: 12px;
    font-weight: 800;
  }

  .section {
    padding: 78px 0;
  }

  .section.soft {
    background: var(--soft);
  }

  .section-head {
    max-width: 760px;
    margin-bottom: 28px;
  }

  .case-layout {
    display: grid;
    grid-template-columns: 300px minmax(0, 1fr);
    gap: clamp(24px, 5vw, 70px);
    align-items: start;
  }

  .case-facts {
    display: grid;
    gap: 14px;
    border-top: 4px solid var(--green);
    background: #f7fafc;
    padding: 18px;
  }

  .case-facts div {
    display: grid;
    gap: 4px;
    border-bottom: 1px solid var(--line);
    padding-bottom: 12px;
  }

  .case-facts div:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .case-facts span {
    color: var(--muted);
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
  }

  .case-facts strong {
    font-family: var(--font-heading);
    font-size: 18px;
  }

  .case-text {
    display: grid;
    gap: 16px;
  }

  .fragment-list {
    display: grid;
    gap: 24px;
  }

  .fragment-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    overflow: hidden;
    margin: 0;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--paper);
  }

  .fragment-card:nth-child(even) {
    grid-template-columns: 360px minmax(0, 1fr);
  }

  .fragment-card:nth-child(even) img {
    order: 2;
  }

  .fragment-card img {
    width: 100%;
    height: 100%;
    min-height: 360px;
    object-fit: cover;
  }

  .fragment-card figcaption {
    display: grid;
    align-content: center;
    gap: 10px;
    padding: clamp(22px, 4vw, 40px);
  }

  .fragment-card span {
    color: var(--blue);
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 800;
  }

  .fragment-card strong {
    font-family: var(--font-heading);
    font-size: 24px;
  }

  .primary-btn {
    display: inline-flex;
    width: fit-content;
    min-height: 44px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--blue);
    border-radius: 8px;
    background: var(--blue);
    color: #ffffff;
    padding: 0 16px;
    font: inherit;
    font-weight: 800;
    cursor: pointer;
  }

  .primary-btn:disabled {
    cursor: not-allowed;
    opacity: 0.55;
  }

  .primary-btn:active {
    transform: translateY(1px);
  }

  @media (max-width: 900px) {
    .header {
      align-items: flex-start;
      flex-direction: column;
    }

    .hero-grid,
    .case-layout,
    .fragment-card,
    .fragment-card:nth-child(even) {
      grid-template-columns: 1fr;
    }

    .hero-grid {
      min-height: auto;
      padding: 52px 0 40px;
    }

    .fragment-card:nth-child(even) img {
      order: 0;
    }

    .fragment-card img {
      min-height: 230px;
    }

    .section {
      padding: 52px 0;
    }
  }
</style>
