---
type BrandLogoVariant = 'horizontal' | 'compact' | 'mark'

type BrandLogoAsset = {
  src: string
  srcset?: string
  width: number
  height: number
}

const assets: Record<BrandLogoVariant, BrandLogoAsset> = {
  horizontal: {
    src: '/brand/poznyak-logo-horizontal.png',
    srcset: '/brand/poznyak-logo-horizontal@2x.png 2x',
    width: 1200,
    height: 390,
  },
  compact: {
    src: '/brand/poznyak-logo-compact.svg',
    width: 1120,
    height: 360,
  },
  mark: {
    src: '/brand/poznyak-logo-mark.svg',
    width: 512,
    height: 512,
  },
}

const {
  variant = 'horizontal',
  class: className = 'brand-logo',
  loading = 'eager',
} = Astro.props as {
  variant?: BrandLogoVariant
  class?: string
  loading?: 'eager' | 'lazy'
}
const asset = assets[variant]
---

<img
  class:list={[className, `brand-logo-${variant}`]}
  src={asset.src}
  srcset={asset.srcset}
  width={asset.width}
  height={asset.height}
  alt=""
  aria-hidden="true"
  loading={loading}
  decoding="async"
/>

<style>
  .brand-logo {
    display: block;
    width: var(--brand-logo-width, 210px);
    max-width: 100%;
    height: auto;
    flex: 0 1 auto;
  }
</style>
