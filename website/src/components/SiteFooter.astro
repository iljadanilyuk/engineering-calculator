---
import BrandMark from './BrandMark.astro'

const contactPhone = (import.meta.env.PUBLIC_CONTACT_PHONE ?? '').trim()
const contactEmail = (import.meta.env.PUBLIC_CONTACT_EMAIL ?? '').trim()
const currentYear = new Date().getFullYear()
---

<footer class="site-footer">
  <div class="footer-shell">
    <div class="footer-main">
      <a class="footer-brand" href="/" aria-label="ИП Позняк, на главную">
        <span class="footer-mark">
          <BrandMark />
        </span>
        <span class="footer-brand-copy">
          <strong>ИП Позняк</strong>
          <span>Проектирование инженерных систем</span>
        </span>
      </a>

      <nav class="footer-nav" aria-label="Навигация в футере">
        <a href="/#calculator">Калькулятор</a>
        <a href="/projects/">Проекты</a>
        <a href="/blog/">Блог</a>
        <a href="/offer/">Получить КП</a>
        <a href="/questionnaire/">Опросник для ТЗ</a>
      </nav>

      <div class="footer-contact" aria-label="Контакты">
        <span>Связь</span>
        <strong>{contactPhone || 'Ответим после заявки'}</strong>
        <a href={contactEmail ? `mailto:${contactEmail}` : '/offer/'}>
          {contactEmail || 'Оставить заявку на сайте'}
        </a>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {currentYear} ИП Позняк</span>
      <span>Работаем по договору с физическими и юридическими лицами</span>
      <span>Минск и вся Беларусь</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid rgba(219, 227, 235, 0.9);
    background:
      radial-gradient(circle at 18% 8%, rgba(62, 142, 234, 0.14), transparent 30%),
      linear-gradient(135deg, #081a2f 0%, #0d2847 58%, #0a2342 100%);
    color: rgba(255, 255, 255, 0.78);
  }

  .footer-shell {
    width: min(var(--shell, 1160px), calc(100% - 32px));
    margin-inline: auto;
    padding: clamp(34px, 6vw, 56px) 0 22px;
  }

  .footer-main {
    display: grid;
    grid-template-columns: minmax(220px, 1fr) minmax(260px, 1.2fr) minmax(210px, 0.8fr);
    gap: clamp(24px, 5vw, 54px);
    align-items: start;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    color: #ffffff;
    text-decoration: none;
  }

  .footer-mark {
    --brand-mark-size: 42px;
    width: 56px;
    height: 56px;
    display: grid;
    flex: 0 0 56px;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.96);
  }

  .footer-brand-copy {
    display: grid;
    gap: 4px;
  }

  .footer-brand-copy strong {
    font-family: var(--font-heading, inherit);
    font-size: 20px;
    line-height: 1.1;
  }

  .footer-brand-copy span,
  .footer-contact span,
  .footer-bottom {
    font-size: 12px;
    line-height: 1.45;
  }

  .footer-nav {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px 18px;
  }

  .footer-nav a,
  .footer-contact a {
    color: rgba(255, 255, 255, 0.84);
    font-size: 14px;
    font-weight: 750;
    line-height: 1.35;
    text-decoration: none;
    transition: color 0.18s ease;
  }

  .footer-nav a:hover,
  .footer-contact a:hover {
    color: #ffffff;
  }

  .footer-contact {
    display: grid;
    gap: 8px;
    justify-items: start;
  }

  .footer-contact span {
    color: #9bbfe3;
    font-weight: 800;
    text-transform: uppercase;
  }

  .footer-contact strong {
    color: #ffffff;
    font-family: var(--font-heading, inherit);
    font-size: 18px;
    line-height: 1.2;
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 12px 24px;
    margin-top: clamp(28px, 5vw, 42px);
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    padding-top: 18px;
    color: rgba(255, 255, 255, 0.56);
  }

  @media (max-width: 820px) {
    .footer-main,
    .footer-nav {
      grid-template-columns: 1fr;
    }

    .footer-bottom {
      display: grid;
      justify-content: start;
    }
  }
</style>
