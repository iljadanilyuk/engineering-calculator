---
import BrandMark from './BrandMark.astro'

type NavItem = {
  href: string
  label: string
  match?: 'exact' | 'prefix'
}

const pathname = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`
const desktopLinks: NavItem[] = [
  { href: '/#calculator', label: 'Калькулятор' },
  { href: '/#benefits', label: 'Что дает проект' },
  { href: '/projects/', label: 'Проекты', match: 'prefix' },
  { href: '/blog/', label: 'Блог', match: 'prefix' },
  { href: '/#process', label: 'Как работаем' },
  { href: '/#faq', label: 'Вопросы' },
]
const mobileLinks: NavItem[] = [
  { href: '/', label: 'Главная', match: 'exact' },
  ...desktopLinks,
  { href: '/offer/', label: 'Получить КП', match: 'exact' },
  { href: '/questionnaire/', label: 'Опросник для ТЗ', match: 'exact' },
  { href: '/#contacts', label: 'Контакты' },
]

function isCurrent(item: NavItem) {
  const hrefPath = item.href.split('#')[0]
  if (!hrefPath) return false

  const normalized = hrefPath.endsWith('/') ? hrefPath : `${hrefPath}/`
  if (item.match === 'exact') return pathname === normalized
  if (item.match === 'prefix') return pathname.startsWith(normalized)
  return false
}
---

<header class="site-header" data-site-header>
  <div class="site-shell site-header-inner">
    <a class="brand" href="/" aria-label="ИП Позняк, на главную">
      <BrandMark />
      <span class="brand-copy">
        <strong>ИП Позняк</strong>
        <span>Инженерные системы</span>
      </span>
    </a>

    <nav class="nav desktop-nav" aria-label="Навигация">
      {
        desktopLinks.map((item) => (
          <a href={item.href} aria-current={isCurrent(item) ? 'page' : undefined}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="header-actions">
      <a
        class="top-cta"
        href="/offer/"
        aria-current={pathname === '/offer/' ? 'page' : undefined}
        data-offer-link
      >
        Получить КП
      </a>
      <button
        class="menu-toggle"
        type="button"
        aria-label="Открыть меню"
        aria-controls="site-mobile-menu"
        aria-expanded="false"
        data-menu-toggle
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div class="mobile-menu" id="site-mobile-menu" data-mobile-menu hidden>
    <nav class="mobile-nav" aria-label="Мобильная навигация">
      {
        mobileLinks.map((item) => (
          <a
            href={item.href}
            aria-current={isCurrent(item) ? 'page' : undefined}
            data-offer-link={item.href === '/offer/' ? '' : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

<script>
  const siteHeaders = document.querySelectorAll('[data-site-header]')

  siteHeaders.forEach((header) => {
    const toggle = header.querySelector('[data-menu-toggle]')
    const menu = header.querySelector('[data-mobile-menu]')
    if (!(toggle instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) return

    const setOpen = (open: boolean) => {
      menu.hidden = !open
      toggle.setAttribute('aria-expanded', String(open))
      toggle.setAttribute('aria-label', open ? 'Закрыть меню' : 'Открыть меню')
    }

    toggle.addEventListener('click', () => {
      setOpen(toggle.getAttribute('aria-expanded') !== 'true')
    })

    menu.addEventListener('click', (event) => {
      if (event.target instanceof HTMLAnchorElement) setOpen(false)
    })

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setOpen(false)
    })
  })
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 70;
    border-bottom: 1px solid rgba(219, 227, 235, 0.95);
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(14px);
  }

  .site-shell {
    width: min(var(--shell, 1160px), calc(100% - 48px));
    margin-inline: auto;
  }

  .site-header-inner {
    min-height: 74px;
    display: grid;
    grid-template-columns: minmax(220px, 240px) 1fr auto;
    align-items: center;
    gap: 28px;
  }

  .brand {
    --brand-mark-size: 44px;
    display: inline-flex;
    align-items: center;
    gap: 11px;
    width: fit-content;
    min-width: 0;
    color: inherit;
    text-decoration: none;
  }

  .brand-copy {
    min-width: 0;
    display: grid;
    gap: 3px;
  }

  .brand-copy strong,
  .brand-copy > span {
    display: block;
  }

  .brand-copy strong {
    font-family: var(--font-heading, inherit);
    font-size: 19px;
    font-weight: 800;
    line-height: 1.1;
  }

  .brand-copy > span {
    color: var(--muted, #6b7785);
    font-size: 11px;
    font-weight: 600;
  }

  .brand:hover {
    --brand-mark-fill: var(--blue, #0b5fb5);
  }

  .brand:hover .brand-copy strong,
  .nav a:hover,
  .mobile-nav a:hover,
  .nav a[aria-current="page"],
  .mobile-nav a[aria-current="page"] {
    color: var(--blue, #0b5fb5);
  }

  .nav {
    display: flex;
    justify-content: center;
    gap: 26px;
    color: var(--body, #465666);
    font-size: 13px;
    font-weight: 700;
  }

  .nav a,
  .top-cta,
  .mobile-nav a {
    color: inherit;
    text-decoration: none;
  }

  .header-actions {
    display: flex;
    align-items: center;
    justify-self: end;
    gap: 8px;
  }

  .top-cta {
    min-height: 46px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    border-radius: 8px;
    background: var(--blue, #0b5fb5);
    box-shadow: 0 10px 26px rgba(11, 95, 181, 0.16);
    color: #ffffff;
    padding: 0 20px;
    font-family: var(--font-body, inherit);
    font-weight: 700;
    line-height: 1.2;
    text-align: center;
    transition: 0.18s ease;
  }

  .top-cta:hover {
    background: #074f9a;
    transform: translateY(-1px);
  }

  .menu-toggle {
    width: 46px;
    height: 46px;
    display: none;
    place-items: center;
    border: 1px solid rgba(11, 95, 181, 0.18);
    border-radius: 8px;
    background: #f5f9fd;
    padding: 0;
    color: var(--navy, var(--ink, #081a2f));
    cursor: pointer;
  }

  .menu-toggle span {
    grid-area: 1 / 1;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    transition: transform 0.18s ease, opacity 0.18s ease;
  }

  .menu-toggle span:nth-child(1) {
    transform: translateY(-6px);
  }

  .menu-toggle span:nth-child(3) {
    transform: translateY(6px);
  }

  .menu-toggle[aria-expanded="true"] span:nth-child(1) {
    transform: rotate(45deg);
  }

  .menu-toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle[aria-expanded="true"] span:nth-child(3) {
    transform: rotate(-45deg);
  }

  .mobile-menu[hidden] {
    display: none;
  }

  .mobile-menu {
    border-top: 1px solid rgba(219, 227, 235, 0.95);
    background: rgba(255, 255, 255, 0.98);
    box-shadow: 0 18px 36px rgba(8, 26, 47, 0.12);
  }

  .mobile-nav {
    width: min(var(--shell, 1160px), calc(100% - 28px));
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    margin-inline: auto;
    padding: 12px 0 16px;
  }

  .mobile-nav a {
    min-height: 42px;
    display: flex;
    align-items: center;
    border: 1px solid rgba(219, 227, 235, 0.9);
    border-radius: 8px;
    background: #f8fbfe;
    padding: 0 12px;
    color: var(--navy, var(--ink, #081a2f));
    font-size: 13px;
    font-weight: 800;
    line-height: 1.2;
  }

  .mobile-nav a[aria-current="page"] {
    border-color: rgba(11, 95, 181, 0.28);
    background: #eef5fb;
  }

  .top-cta:focus-visible,
  .menu-toggle:focus-visible,
  .nav a:focus-visible,
  .mobile-nav a:focus-visible {
    outline: 3px solid rgba(11, 95, 181, 0.35);
    outline-offset: 2px;
  }

  @media (max-width: 1100px) {
    .site-header-inner {
      grid-template-columns: minmax(220px, 240px) auto;
    }

    .desktop-nav {
      display: none;
    }

    .menu-toggle {
      display: grid;
    }
  }

  @media (max-width: 820px) {
    .site-shell {
      width: min(100% - 28px, var(--shell, 1160px));
    }

    .site-header-inner {
      min-height: 66px;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 10px;
    }

    .brand {
      --brand-mark-size: 38px;
      gap: 9px;
    }

    .brand-copy strong {
      font-size: 16px;
    }

    .brand-copy > span {
      max-width: 150px;
      font-size: 10px;
      line-height: 1.25;
    }

    .top-cta {
      min-height: 38px;
      padding: 0 12px;
      font-size: 12px;
    }

    .menu-toggle {
      width: 38px;
      height: 38px;
    }
  }

  @media (max-width: 380px) {
    .site-shell {
      width: min(100% - 20px, var(--shell, 1160px));
    }

    .brand-copy strong {
      font-size: 14px;
    }

    .brand-copy > span {
      display: none;
    }

    .top-cta {
      padding: 0 10px;
    }
  }
</style>
