generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ServicePricingType {
  fixed
  per_sqm
  formula

  @@map("service_pricing_type")
}

enum UserRole {
  admin
  member

  @@map("user_role")
}

enum TelegramDeliveryTargetType {
  proposal
  project_examples

  @@map("telegram_delivery_target_type")
}

enum TelegramDeliveryStatus {
  disabled
  pending_start
  sent
  failed

  @@map("telegram_delivery_status")
}

enum BlogPostStatus {
  draft
  published
  archived

  @@map("blog_post_status")
}

model User {
  id           String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  email        String        @unique
  passwordHash String        @map("password_hash")
  displayName  String?       @map("display_name")
  role         UserRole      @default(member)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  sessions     AuthSession[]

  @@map("users")
}

model Service {
  id            String             @id @default(dbgenerated("uuidv7()")) @db.Uuid
  title         String
  description   String?
  pricingType   ServicePricingType @map("pricing_type")
  priceUsdCents BigInt             @map("price_usd_cents") @db.BigInt
  pricingRule   Json?              @map("pricing_rule")
  formulaVersion String?           @map("formula_version")
  isActive      Boolean            @default(true) @map("is_active")
  isPublic      Boolean            @default(true) @map("is_public")
  sortOrder     Int                @default(0) @map("sort_order")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@index([isActive, isPublic, sortOrder], map: "services_visibility_sort_idx")
  @@map("services")
}

model Calculation {
  id                     String     @id @default(dbgenerated("uuidv7()")) @db.Uuid
  publicToken            String     @unique @map("public_token")
  idempotencyKey         String?    @unique(map: "calculations_idempotency_key_key") @map("idempotency_key")
  requestFingerprintHash String?    @map("request_fingerprint_hash")
  duplicateFingerprintHash String?  @unique(map: "calculations_duplicate_fingerprint_hash_key") @map("duplicate_fingerprint_hash")
  duplicateWindowStartedAt DateTime? @map("duplicate_window_started_at")
  clientName             String     @map("client_name")
  clientPhone            String     @map("client_phone")
  objectName             String?    @map("object_name")
  areaSqm                String     @map("area_sqm")
  areaSqmHundredths      BigInt     @map("area_sqm_hundredths") @db.BigInt
  selectedServiceIds     Json       @map("selected_service_ids")
  serviceSnapshots       Json       @map("service_snapshots")
  skippedServices        Json       @map("skipped_services")
  exchangeRate           Json       @map("exchange_rate")
  usdToBynRateScaled     Int        @map("usd_to_byn_rate_scaled")
  usdToBynRateScale      Int        @default(10000) @map("usd_to_byn_rate_scale")
  calculationVersion     String     @map("calculation_version")
  calculationSnapshot    Json       @map("calculation_snapshot")
  totalUsdCents          BigInt     @map("total_usd_cents") @db.BigInt
  totalBynCents          BigInt     @map("total_byn_cents") @db.BigInt
  totalBynRoundedRubles  BigInt     @map("total_byn_rounded_rubles") @db.BigInt
  status                 String     @default("new")
  statusUpdatedAt        DateTime   @default(now()) @map("status_updated_at")
  notes                  String?
  source                 String?
  referrer               String?
  utm                    Json?
  consentAcceptedAt      DateTime?  @map("consent_accepted_at")
  consentVersion         String?    @map("consent_version")
  consentText            String?    @map("consent_text")
  consentIpAddress       String?    @map("consent_ip_address")
  consentUserAgent       String?    @map("consent_user_agent")
  createdAt              DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @updatedAt @map("updated_at")
  proposals              Proposal[]
  questionnaire          CalculationQuestionnaire?
  telegramDeliveries     TelegramDelivery[]

  @@index([createdAt], map: "calculations_created_at_idx")
  @@index([status, createdAt], map: "calculations_status_created_at_idx")
  @@index([clientPhone], map: "calculations_client_phone_idx")
  @@index([clientPhone, createdAt], map: "calculations_client_phone_created_at_idx")
  @@index([duplicateWindowStartedAt], map: "calculations_duplicate_window_started_at_idx")
  @@map("calculations")
}

model CalculationQuestionnaire {
  id                     String      @id @default(dbgenerated("uuidv7()")) @db.Uuid
  calculationId          String      @unique(map: "calculation_questionnaires_calculation_id_key") @db.Uuid @map("calculation_id")
  idempotencyKey         String      @unique(map: "calculation_questionnaires_idempotency_key_key") @map("idempotency_key")
  requestFingerprintHash String      @map("request_fingerprint_hash")
  questionnaireVersion   String      @map("questionnaire_version")
  answersSnapshot        Json        @map("answers_snapshot")
  source                 String?
  referrer               String?
  utm                    Json?
  consentAcceptedAt      DateTime?   @map("consent_accepted_at")
  consentVersion         String?     @map("consent_version")
  consentText            String?     @map("consent_text")
  consentIpAddress       String?     @map("consent_ip_address")
  consentUserAgent       String?     @map("consent_user_agent")
  createdAt              DateTime    @default(now()) @map("created_at")
  updatedAt              DateTime    @updatedAt @map("updated_at")
  calculation            Calculation @relation(fields: [calculationId], references: [id], onDelete: Restrict, map: "calculation_questionnaires_calculation_id_fkey")

  @@index([createdAt], map: "calculation_questionnaires_created_at_idx")
  @@index([updatedAt], map: "calculation_questionnaires_updated_at_idx")
  @@map("calculation_questionnaires")
}

model Proposal {
  id                  String      @id @default(dbgenerated("uuidv7()")) @db.Uuid
  calculationId       String      @db.Uuid @map("calculation_id")
  publicToken         String      @unique @map("public_token")
  offerNumber         String      @map("offer_number")
  templateVersion     String      @map("template_version")
  pdfUrl              String?     @map("pdf_url")
  storageKey          String?     @map("storage_key")
  checksumSha256      String?     @map("checksum_sha256")
  pdfBytes            Bytes?      @map("pdf_bytes")
  pdfByteSize         Int?        @map("pdf_byte_size")
  htmlSnapshot        String?     @map("html_snapshot")
  calculationSnapshot Json        @map("calculation_snapshot")
  createdAt           DateTime    @default(now()) @map("created_at")
  calculation         Calculation @relation(fields: [calculationId], references: [id], onDelete: Restrict, map: "proposals_calculation_id_fkey")

  @@index([calculationId], map: "proposals_calculation_id_idx")
  @@map("proposals")
}

model AppSetting {
  key       String   @id
  value     Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model ProjectExample {
  id                  String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  slug                String   @unique
  title               String
  description         String?
  objectType          String?  @map("object_type")
  location            String?
  areaSqm             String?  @map("area_sqm")
  engineeringSections Json     @default("[]") @map("engineering_sections")
  initialTask         String?  @map("initial_task")
  solutionSummary     String?  @map("solution_summary")
  fragments           Json     @default("[]")
  exampleSlugs        Json     @default("[]") @map("example_slugs")
  fileUrl             String   @map("file_url")
  coverImageUrl       String?  @map("cover_image_url")
  isPublic            Boolean  @default(true) @map("is_public")
  isArchived          Boolean  @default(false) @map("is_archived")
  sortOrder           Int      @default(0) @map("sort_order")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([isPublic, isArchived, sortOrder], map: "project_examples_public_sort_idx")
  @@map("project_examples")
}

model ProjectExampleRequest {
  id                     String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  publicToken            String   @unique @map("public_token")
  idempotencyKey         String?  @unique(map: "project_example_requests_idempotency_key_key") @map("idempotency_key")
  requestFingerprintHash String?  @map("request_fingerprint_hash")
  clientName             String   @map("client_name")
  clientPhone            String   @map("client_phone")
  requestedExampleSlugs  Json     @map("requested_example_slugs")
  source                 String?
  referrer               String?
  utm                    Json?
  consentAcceptedAt      DateTime? @map("consent_accepted_at")
  consentVersion         String?  @map("consent_version")
  consentText            String?  @map("consent_text")
  consentIpAddress       String?  @map("consent_ip_address")
  consentUserAgent       String?  @map("consent_user_agent")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")
  telegramDeliveries     TelegramDelivery[]

  @@index([createdAt], map: "project_example_requests_created_at_idx")
  @@index([clientPhone, createdAt], map: "project_example_requests_client_phone_created_at_idx")
  @@map("project_example_requests")
}

model BlogPost {
  id            String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  slug          String         @unique
  title         String
  excerpt       String
  content       String
  coverImageUrl String?        @map("cover_image_url")
  category      String?
  tags          Json           @default("[]")
  seoTitle      String?        @map("seo_title")
  seoDescription String?       @map("seo_description")
  status        BlogPostStatus @default(draft)
  publishedAt   DateTime?     @map("published_at")
  sortOrder     Int           @default(0) @map("sort_order")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([status, publishedAt, sortOrder], map: "blog_posts_public_sort_idx")
  @@index([updatedAt], map: "blog_posts_updated_at_idx")
  @@map("blog_posts")
}

model TelegramDelivery {
  id                      String                     @id @default(dbgenerated("uuidv7()")) @db.Uuid
  targetType              TelegramDeliveryTargetType @map("target_type")
  status                  TelegramDeliveryStatus     @default(pending_start)
  statusMessage           String?                    @map("status_message")
  bindToken               String                     @unique(map: "telegram_deliveries_bind_token_key") @map("bind_token")
  calculationId           String?                    @db.Uuid @map("calculation_id")
  projectExampleRequestId String?                    @db.Uuid @map("project_example_request_id")
  telegramChatId          String?                    @map("telegram_chat_id")
  telegramUserId          String?                    @map("telegram_user_id")
  telegramUsername        String?                    @map("telegram_username")
  telegramFirstName       String?                    @map("telegram_first_name")
  attemptCount            Int                        @default(0) @map("attempt_count")
  lastAttemptAt           DateTime?                  @map("last_attempt_at")
  deliveredAt             DateTime?                  @map("delivered_at")
  expiresAt               DateTime?                  @map("expires_at")
  createdAt               DateTime                   @default(now()) @map("created_at")
  updatedAt               DateTime                   @updatedAt @map("updated_at")
  calculation             Calculation?               @relation(fields: [calculationId], references: [id], onDelete: Restrict, map: "telegram_deliveries_calculation_id_fkey")
  projectExampleRequest   ProjectExampleRequest?     @relation(fields: [projectExampleRequestId], references: [id], onDelete: Restrict, map: "telegram_deliveries_project_example_request_id_fkey")

  @@index([calculationId], map: "telegram_deliveries_calculation_id_idx")
  @@index([projectExampleRequestId], map: "telegram_deliveries_project_example_request_id_idx")
  @@index([status, createdAt], map: "telegram_deliveries_status_created_at_idx")
  @@index([expiresAt], map: "telegram_deliveries_expires_at_idx")
  @@map("telegram_deliveries")
}

model AuthSession {
  id               String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId           String    @db.Uuid @map("user_id")
  refreshTokenHash String    @unique(map: "auth_sessions_refresh_token_hash_key") @map("refresh_token_hash")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade, map: "auth_sessions_user_id_fkey")

  @@index([userId], map: "auth_sessions_user_id_idx")
  @@index([expiresAt], map: "auth_sessions_expires_at_idx")
  @@map("auth_sessions")
}

model AuthRateLimitBucket {
  id              String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  scope           String
  bucketKey       String   @map("bucket_key")
  failedCount     Int      @default(0) @map("failed_count")
  windowStartedAt DateTime @map("window_started_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([scope, bucketKey], map: "auth_rate_limit_buckets_scope_bucket_key_key")
  @@index([windowStartedAt], map: "auth_rate_limit_buckets_window_started_at_idx")
  @@map("auth_rate_limit_buckets")
}
